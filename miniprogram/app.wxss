/* ===== 全局设计系统 v1.1 - iOS 液态玻璃风格 ===== */

/* 色彩变量 */
page {
  --color-primary: #8B6CF6;
  --color-primary-dark: #7C5CFC;
  --color-primary-light: #B49DFB;
  --color-primary-pale: #D4C8FD;
  --color-primary-faint: #EDE8FE;
  --color-primary-gradient: linear-gradient(135deg, #8B6CF6, #B49DFB);
  
  --color-bg: #F7F5FF;
  --color-accent: #FF6B9D;
  --color-accent-gradient: linear-gradient(135deg, #FF6B9D, #FFB8D1);
  --color-success: #34C759;
  --color-warning: #FF9500;
  --color-danger: #FF3B30;
  
  --color-text-title: #1A1A2E;
  --color-text-body: #333344;
  --color-text-secondary: #666677;
  --color-text-placeholder: #9999AA;
  --color-text-white: #FFFFFF;
  
  --color-card-bg: rgba(255, 255, 255, 0.85);
  --color-card-border: rgba(237, 232, 254, 0.8);
  --color-divider: #E8E8F0;
  --color-input-bg: #F5F3FA;
  
  /* 液态玻璃阴影 - 带紫色调，更柔和 */
  --shadow-glass-small: 0 2px 12px rgba(139, 108, 246, 0.06), inset 0 1px 0 rgba(255, 255, 255, 0.4);
  --shadow-glass-medium: 0 4px 20px rgba(139, 108, 246, 0.08), inset 0 1px 0 rgba(255, 255, 255, 0.5);
  --shadow-glass-large: 0 8px 32px rgba(139, 108, 246, 0.12), inset 0 1px 0 rgba(255, 255, 255, 0.6);
  --shadow-glass-float: 0 12px 40px rgba(139, 108, 246, 0.15), inset 0 1px 0 rgba(255, 255, 255, 0.7);
  --shadow-color: 0 8px 24px rgba(139, 108, 246, 0.20);
  
  --radius-page-card: 20rpx;
  --radius-btn: 14rpx;
  --radius-capsule: 9999px;
  --radius-input: 14rpx;
  --radius-tag: 10rpx;
  --radius-popup: 24rpx;
  
  --spacing-page: 20rpx;
  --spacing-section: 28rpx;
  --spacing-element: 20rpx;
  --spacing-compact: 16rpx;
  --spacing-micro: 10rpx;
  
  background-color: var(--color-bg);
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'SF Pro SC', 'Helvetica Neue', 'Microsoft YaHei', sans-serif;
  color: var(--color-text-body);
  font-size: 14px;
  line-height: 1.6;
}

/* 全局工具类 */
.container {
  padding: var(--spacing-page);
  padding-bottom: calc(var(--spacing-page) + env(safe-area-inset-bottom));
}

/* 液态玻璃卡片 - 增强版 */
.glass-card {
  background: rgba(255, 255, 255, 0.72);
  backdrop-filter: blur(20px) saturate(180%);
  -webkit-backdrop-filter: blur(20px) saturate(180%);
  border: 1px solid rgba(255, 255, 255, 0.5);
  box-shadow: 0 8px 32px rgba(139, 108, 246, 0.08), inset 0 1px 0 rgba(255, 255, 255, 0.5);
  border-radius: var(--radius-page-card);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.glass-card:active {
  transform: scale(0.985);
  box-shadow: 0 4px 16px rgba(139, 108, 246, 0.06), inset 0 1px 0 rgba(255, 255, 255, 0.4);
}

/* 渐变按钮 - 液态玻璃质感 */
.gradient-btn {
  width: 100%;
  height: 100rpx;
  border-radius: var(--radius-capsule);
  background: linear-gradient(135deg, #8B6CF6 0%, #B49DFB 50%, #C4B5FD 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow: 0 8px 28px rgba(139, 108, 246, 0.35), inset 0 1px 0 rgba(255,255,255,0.3);
  position: relative;
  overflow: hidden;
  transition: all 0.2s ease;
}

.gradient-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
  transition: left 0.5s ease;
}

.gradient-btn:active::before {
  left: 100%;
}

.gradient-btn::after {
  border: none;
}

.gradient-btn:active {
  opacity: 0.92;
  transform: scale(0.97);
  box-shadow: 0 4px 16px rgba(139, 108, 246, 0.25), inset 0 1px 0 rgba(255,255,255,0.2);
}

.accent-btn {
  width: 100%;
  height: 100rpx;
  border-radius: var(--radius-capsule);
  background: linear-gradient(135deg, #FF6B9D 0%, #FFB8D1 50%, #FFC4E0 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow: 0 8px 28px rgba(255, 107, 157, 0.35), inset 0 1px 0 rgba(255,255,255,0.3);
  transition: all 0.2s ease;
}

.accent-btn::after {
  border: none;
}

.accent-btn:active {
  opacity: 0.92;
  transform: scale(0.97);
}

/* 导航栏 - 液态玻璃效果增强 */
.glass-nav {
  background: rgba(247, 245, 255, 0.85);
  backdrop-filter: blur(24px) saturate(180%);
  -webkit-backdrop-filter: blur(24px) saturate(180%);
  border-bottom: 1px solid rgba(237, 232, 254, 0.5);
  box-shadow: 0 2px 16px rgba(139, 108, 246, 0.04);
}

/* 深色背景页面 */
.dark-bg {
  background: linear-gradient(180deg, #1A1A2E 0%, #2D2D45 50%, #1A1A2E 100%);
}

/* 卡片列表项 - 液态玻璃风格 */
.card-item {
  background: rgba(255, 255, 255, 0.72);
  border: 1px solid rgba(255, 255, 255, 0.4);
  border-radius: var(--radius-page-card);
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-glass-small);
  backdrop-filter: blur(16px) saturate(180%);
  -webkit-backdrop-filter: blur(16px) saturate(180%);
  transition: all 0.2s ease;
}

.card-item:active {
  transform: scale(0.985);
  box-shadow: 0 2px 8px rgba(139, 108, 246, 0.04);
}

/* 分割线 */
.divider {
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--color-divider), transparent);
  margin: 20rpx 0;
}

/* 标签 - 液态玻璃质感 */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 18rpx;
  border-radius: var(--radius-tag);
  font-size: 22rpx;
  font-weight: 500;
  background: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  border: 1px solid rgba(255, 255, 255, 0.3);
  transition: all 0.2s ease;
}

.tag:active {
  transform: scale(0.95);
}

.tag-primary {
  background: rgba(139, 108, 246, 0.12);
  color: var(--color-primary);
  border-color: rgba(139, 108, 246, 0.2);
}

.tag-success {
  background: rgba(52, 199, 89, 0.12);
  color: var(--color-success);
  border-color: rgba(52, 199, 89, 0.2);
}

.tag-warning {
  background: rgba(255, 149, 0, 0.12);
  color: var(--color-warning);
  border-color: rgba(255, 149, 0, 0.2);
}

.tag-danger {
  background: rgba(255, 59, 48, 0.12);
  color: var(--color-danger);
  border-color: rgba(255, 59, 48, 0.2);
}

.tag-accent {
  background: rgba(255, 107, 157, 0.12);
  color: var(--color-accent);
  border-color: rgba(255, 107, 157, 0.2);
}

/* 进度条 - 液态光泽 */
.progress-bar {
  height: 10rpx;
  background: rgba(139, 108, 246, 0.1);
  border-radius: 5rpx;
  overflow: hidden;
  box-shadow: inset 0 1px 3px rgba(139, 108, 246, 0.08);
}

.progress-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #8B6CF6 0%, #B49DFB 50%, #C4B5FD 100%);
  border-radius: 5rpx;
  transition: width 600ms cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 1px 4px rgba(139, 108, 246, 0.3);
  position: relative;
}

.progress-bar-fill::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
  animation: shimmer 2s infinite;
}

@keyframes shimmer {
  0% { transform: translateX(-100%); }
  100% { transform: translateX(100%); }
}

/* 空状态 - 呼吸感设计 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 48rpx;
  background: rgba(255, 255, 255, 0.5);
  border-radius: var(--radius-page-card);
  border: 1px dashed rgba(139, 108, 246, 0.2);
}

/* 隐藏滚动条但保留功能 */
::-webkit-scrollbar {
  display: none;
  width: 0;
  height: 0;
  color: transparent;
}

/* 呼吸动画 - 用于强调元素 */
@keyframes breathe {
  0%, 100% { transform: scale(1); opacity: 1; }
  50% { transform: scale(1.02); opacity: 0.95; }
}

.breathe-animation {
  animation: breathe 3s ease-in-out infinite;
}

/* 脉冲动画 - 用于加载/等待状态 */
@keyframes pulse-glow {
  0%, 100% { box-shadow: 0 4px 16px rgba(139, 108, 246, 0.2); }
  50% { box-shadow: 0 4px 28px rgba(139, 108, 246, 0.4); }
}

.pulse-glow {
  animation: pulse-glow 2s ease-in-out infinite;
}

/* 浮动动画 - 用于卡片悬浮效果 */
@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-4rpx); }
}

.float-animation {
  animation: float 4s ease-in-out infinite;
}
