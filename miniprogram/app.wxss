/* ===== 全局设计系统 v2.0 - iOS 液态玻璃风格重构 ===== */
/* 设计理念：科技感 · 亲和力 · 呼吸感 */

/* 色彩变量 - 紫藤色系 */
page {
  --color-primary: #8B6CF6;
  --color-primary-dark: #7C5CFC;
  --color-primary-light: #B49DFB;
  --color-primary-pale: #D4C8FD;
  --color-primary-faint: #EDE8FE;
  --color-primary-gradient: linear-gradient(135deg, #8B6CF6, #B49DFB);
  
  --color-bg: #F7F5FF;
  --color-bg-gradient: linear-gradient(180deg, #FAF8FF 0%, #F2EEFF 100%);
  --color-accent: #FF6B9D;
  --color-accent-gradient: linear-gradient(135deg, #FF6B9D, #FFB8D1);
  --color-success: #34C759;
  --color-warning: #FF9500;
  --color-danger: #FF3B30;
  --color-info: #5AC8FA;
  
  --color-text-title: #1A1A2E;
  --color-text-body: #333344;
  --color-text-secondary: #666677;
  --color-text-placeholder: #9999AA;
  --color-text-white: #FFFFFF;
  --color-text-on-primary: #FFFFFF;
  
  /* 液态玻璃卡片背景 - 多层叠加营造深度感 */
  --color-card-bg: rgba(255, 255, 255, 0.72);
  --color-card-bg-hover: rgba(255, 255, 255, 0.85);
  --color-card-border: rgba(255, 255, 255, 0.5);
  --color-card-border-strong: rgba(237, 232, 254, 0.8);
  --color-divider: rgba(232, 232, 240, 0.6);
  --color-input-bg: rgba(245, 243, 250, 0.8);
  
  /* 液态玻璃阴影系统 - 带紫色调的柔和阴影 */
  --shadow-glass-sm: 0 2px 8px rgba(139, 108, 246, 0.04), inset 0 1px 0 rgba(255, 255, 255, 0.4);
  --shadow-glass-md: 0 4px 16px rgba(139, 108, 246, 0.06), inset 0 1px 0 rgba(255, 255, 255, 0.5);
  --shadow-glass-lg: 0 8px 32px rgba(139, 108, 246, 0.08), inset 0 1px 0 rgba(255, 255, 255, 0.6);
  --shadow-glass-xl: 0 12px 48px rgba(139, 108, 246, 0.12), inset 0 1px 0 rgba(255, 255, 255, 0.7);
  --shadow-glass-float: 0 16px 64px rgba(139, 108, 246, 0.15), inset 0 1px 0 rgba(255, 255, 255, 0.8);
  --shadow-color-primary: 0 8px 24px rgba(139, 108, 246, 0.25);
  --shadow-color-accent: 0 8px 24px rgba(255, 107, 157, 0.25);
  
  /* 圆角系统 - 大圆角营造亲和力 */
  --radius-xs: 8rpx;
  --radius-sm: 12rpx;
  --radius-md: 16rpx;
  --radius-lg: 20rpx;
  --radius-xl: 24rpx;
  --radius-2xl: 32rpx;
  --radius-capsule: 9999px;
  --radius-circle: 50%;
  
  /* 间距系统 - 基于8px网格 */
  --spacing-xs: 8rpx;
  --spacing-sm: 12rpx;
  --spacing-md: 16rpx;
  --spacing-lg: 20rpx;
  --spacing-xl: 24rpx;
  --spacing-2xl: 28rpx;
  --spacing-3xl: 32rpx;
  --spacing-page: 24rpx;
  
  /* 模糊强度 */
  --blur-sm: blur(8px);
  --blur-md: blur(16px);
  --blur-lg: blur(24px);
  --blur-xl: blur(32px);
  
  /* 字体大小 */
  --font-xs: 20rpx;
  --font-sm: 22rpx;
  --font-md: 24rpx;
  --font-lg: 26rpx;
  --font-xl: 28rpx;
  --font-2xl: 30rpx;
  --font-3xl: 32rpx;
  --font-4xl: 36rpx;
  --font-display: 44rpx;
  
  background: var(--color-bg-gradient);
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'SF Pro SC', 'Helvetica Neue', 'Microsoft YaHei', sans-serif;
  color: var(--color-text-body);
  font-size: 14px;
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

/* 全局工具类 */
.container {
  padding: var(--spacing-page);
  padding-bottom: calc(var(--spacing-page) + env(safe-area-inset-bottom));
}

/* ===== 液态玻璃卡片系统 v2.0 ===== */

/* 基础液态玻璃卡片 - 增强模糊和光泽感 */
.glass-card {
  background: rgba(255, 255, 255, 0.65);
  backdrop-filter: blur(24px) saturate(200%);
  -webkit-backdrop-filter: blur(24px) saturate(200%);
  border: 1px solid rgba(255, 255, 255, 0.6);
  box-shadow: 
    0 8px 32px rgba(139, 108, 246, 0.08),
    0 2px 8px rgba(139, 108, 246, 0.04),
    inset 0 1px 0 rgba(255, 255, 255, 0.7),
    inset 0 -1px 0 rgba(255, 255, 255, 0.3);
  border-radius: var(--radius-2xl);
  transition: all 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
  will-change: transform, box-shadow;
}

.glass-card:hover {
  background: rgba(255, 255, 255, 0.78);
  box-shadow: 
    0 12px 48px rgba(139, 108, 246, 0.12),
    0 4px 12px rgba(139, 108, 246, 0.06),
    inset 0 1px 0 rgba(255, 255, 255, 0.8);
}

.glass-card:active {
  transform: scale(0.98);
  box-shadow: 
    0 4px 16px rgba(139, 108, 246, 0.06),
    inset 0 1px 0 rgba(255, 255, 255, 0.5);
}

/* 紧凑型玻璃卡片 */
.glass-card-compact {
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(16px) saturate(180%);
  -webkit-backdrop-filter: blur(16px) saturate(180%);
  border: 1px solid rgba(255, 255, 255, 0.5);
  box-shadow: var(--shadow-glass-md);
  border-radius: var(--radius-xl);
  transition: all 0.25s ease;
}

.glass-card-compact:active {
  transform: scale(0.985);
}

/* 凸起式玻璃卡片 - 用于重要内容 */
.glass-card-elevated {
  background: rgba(255, 255, 255, 0.8);
  backdrop-filter: blur(32px) saturate(220%);
  -webkit-backdrop-filter: blur(32px) saturate(220%);
  border: 1px solid rgba(255, 255, 255, 0.7);
  box-shadow: 
    0 16px 64px rgba(139, 108, 246, 0.15),
    0 8px 24px rgba(139, 108, 246, 0.08),
    inset 0 1px 0 rgba(255, 255, 255, 0.9);
  border-radius: var(--radius-2xl);
}

/* 渐变按钮 - 液态玻璃质感增强版 */
.gradient-btn {
  width: 100%;
  height: 100rpx;
  border-radius: var(--radius-capsule);
  background: linear-gradient(135deg, #8B6CF6 0%, #9B7CF8 35%, #B49DFB 70%, #C4B5FD 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow: 
    0 12px 36px rgba(139, 108, 246, 0.4),
    0 4px 12px rgba(139, 108, 246, 0.2),
    inset 0 1px 0 rgba(255, 255, 255, 0.4),
    inset 0 -1px 0 rgba(0, 0, 0, 0.05);
  position: relative;
  overflow: hidden;
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  will-change: transform, box-shadow;
}

.gradient-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
  transition: left 0.6s ease;
}

.gradient-btn:active::before {
  left: 100%;
}

.gradient-btn:active {
  opacity: 0.9;
  transform: scale(0.96);
  box-shadow: 
    0 6px 20px rgba(139, 108, 246, 0.3),
    inset 0 1px 0 rgba(255, 255, 255, 0.3);
}

/* 强调按钮 - 珊瑚粉渐变 */
.accent-btn {
  width: 100%;
  height: 100rpx;
  border-radius: var(--radius-capsule);
  background: linear-gradient(135deg, #FF6B9D 0%, #FF85AD 35%, #FFB8D1 70%, #FFC4E0 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow: 
    0 12px 36px rgba(255, 107, 157, 0.4),
    0 4px 12px rgba(255, 107, 157, 0.2),
    inset 0 1px 0 rgba(255, 255, 255, 0.4);
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  will-change: transform, box-shadow;
}

.accent-btn:active {
  opacity: 0.9;
  transform: scale(0.96);
}

/* 次要按钮 - 幽灵风格 */
.ghost-btn {
  width: 100%;
  height: 96rpx;
  border-radius: var(--radius-capsule);
  background: rgba(255, 255, 255, 0.5);
  border: 2px solid rgba(139, 108, 246, 0.3);
  color: var(--color-primary);
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.25s ease;
}

.ghost-btn:active {
  background: rgba(139, 108, 246, 0.1);
  border-color: rgba(139, 108, 246, 0.5);
  transform: scale(0.97);
}

/* ===== 导航栏系统 v2.0 ===== */

/* 液态玻璃导航栏 - 增强模糊效果 */
.glass-nav {
  background: rgba(247, 245, 255, 0.88);
  backdrop-filter: blur(32px) saturate(200%);
  -webkit-backdrop-filter: blur(32px) saturate(200%);
  border-bottom: 1px solid rgba(237, 232, 254, 0.6);
  box-shadow: 
    0 4px 24px rgba(139, 108, 246, 0.06),
    0 1px 4px rgba(139, 108, 246, 0.03);
  will-change: backdrop-filter;
}

/* 深色背景页面 */
.dark-bg {
  background: linear-gradient(180deg, #1A1A2E 0%, #2D2D45 50%, #1A1A2E 100%);
}

/* 深色液态玻璃卡片 */
.dark-glass-card {
  background: rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(24px) saturate(180%);
  -webkit-backdrop-filter: blur(24px) saturate(180%);
  border: 1px solid rgba(255, 255, 255, 0.12);
  box-shadow: 
    0 8px 32px rgba(0, 0, 0, 0.2),
    inset 0 1px 0 rgba(255, 255, 255, 0.1);
  border-radius: var(--radius-2xl);
}

/* ===== 卡片列表项系统 ===== */

/* 卡片列表项 - 液态玻璃风格增强 */
.card-item {
  background: rgba(255, 255, 255, 0.7);
  border: 1px solid rgba(255, 255, 255, 0.5);
  border-radius: var(--radius-2xl);
  padding: var(--spacing-2xl);
  margin-bottom: var(--spacing-lg);
  box-shadow: var(--shadow-glass-md);
  backdrop-filter: blur(20px) saturate(180%);
  -webkit-backdrop-filter: blur(20px) saturate(180%);
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  will-change: transform, box-shadow;
}

.card-item:hover {
  background: rgba(255, 255, 255, 0.8);
  box-shadow: var(--shadow-glass-lg);
  transform: translateY(-2rpx);
}

.card-item:active {
  transform: scale(0.985) translateY(0);
  box-shadow: var(--shadow-glass-sm);
}

/* ===== 分割线系统 ===== */

/* 基础分割线 - 渐变透明效果 */
.divider {
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(232, 232, 240, 0.5), transparent);
  margin: var(--spacing-lg) 0;
}

/* 细分割线 */
.divider-thin {
  height: 0.5px;
  background: linear-gradient(90deg, transparent, rgba(232, 232, 240, 0.3), transparent);
}

/* 强调分割线 - 带紫色调 */
.divider-primary {
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(139, 108, 246, 0.3), transparent);
}

/* ===== 标签系统 v2.0 - 液态玻璃质感 ===== */

/* 基础标签 */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 20rpx;
  border-radius: var(--radius-capsule);
  font-size: var(--font-sm);
  font-weight: 500;
  background: rgba(255, 255, 255, 0.65);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid rgba(255, 255, 255, 0.4);
  box-shadow: 
    0 2px 8px rgba(139, 108, 246, 0.04),
    inset 0 1px 0 rgba(255, 255, 255, 0.5);
  transition: all 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
  will-change: transform, background;
}

.tag:active {
  transform: scale(0.92);
  background: rgba(255, 255, 255, 0.75);
}

/* 主色标签 */
.tag-primary {
  background: rgba(139, 108, 246, 0.15);
  color: var(--color-primary);
  border-color: rgba(139, 108, 246, 0.25);
  box-shadow: 
    0 2px 8px rgba(139, 108, 246, 0.08),
    inset 0 1px 0 rgba(139, 108, 246, 0.1);
}

/* 成功标签 */
.tag-success {
  background: rgba(52, 199, 89, 0.15);
  color: var(--color-success);
  border-color: rgba(52, 199, 89, 0.25);
  box-shadow: 
    0 2px 8px rgba(52, 199, 89, 0.08),
    inset 0 1px 0 rgba(52, 199, 89, 0.1);
}

/* 警告标签 */
.tag-warning {
  background: rgba(255, 149, 0, 0.15);
  color: var(--color-warning);
  border-color: rgba(255, 149, 0, 0.25);
  box-shadow: 
    0 2px 8px rgba(255, 149, 0, 0.08),
    inset 0 1px 0 rgba(255, 149, 0, 0.1);
}

/* 危险标签 */
.tag-danger {
  background: rgba(255, 59, 48, 0.15);
  color: var(--color-danger);
  border-color: rgba(255, 59, 48, 0.25);
  box-shadow: 
    0 2px 8px rgba(255, 59, 48, 0.08),
    inset 0 1px 0 rgba(255, 59, 48, 0.1);
}

/* 强调标签 */
.tag-accent {
  background: rgba(255, 107, 157, 0.15);
  color: var(--color-accent);
  border-color: rgba(255, 107, 157, 0.25);
  box-shadow: 
    0 2px 8px rgba(255, 107, 157, 0.08),
    inset 0 1px 0 rgba(255, 107, 157, 0.1);
}

/* 信息标签 */
.tag-info {
  background: rgba(90, 200, 250, 0.15);
  color: var(--color-info);
  border-color: rgba(90, 200, 250, 0.25);
}

/* ===== 进度条系统 v2.0 - 液态光泽 ===== */

/* 基础进度条容器 */
.progress-bar {
  height: 12rpx;
  background: rgba(139, 108, 246, 0.08);
  border-radius: var(--radius-capsule);
  overflow: hidden;
  box-shadow: 
    inset 0 1px 3px rgba(139, 108, 246, 0.06),
    inset 0 -1px 2px rgba(255, 255, 255, 0.3);
  position: relative;
}

/* 进度条填充 */
.progress-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #8B6CF6 0%, #9B7CF8 35%, #B49DFB 70%, #C4B5FD 100%);
  border-radius: var(--radius-capsule);
  transition: width 700ms cubic-bezier(0.34, 1.56, 0.64, 1);
  box-shadow: 
    0 2px 8px rgba(139, 108, 246, 0.35),
    inset 0 1px 0 rgba(255, 255, 255, 0.4);
  position: relative;
  overflow: hidden;
}

/* 液态光泽动画层 */
.progress-bar-fill::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(
    90deg,
    transparent 0%,
    rgba(255, 255, 255, 0.4) 50%,
    transparent 100%
  );
  animation: shimmer 2.5s ease-in-out infinite;
}

@keyframes shimmer {
  0% { transform: translateX(-100%); }
  100% { transform: translateX(100%); }
}

/* 小型进度条 */
.progress-bar-sm {
  height: 8rpx;
}

/* 大型进度条 */
.progress-bar-lg {
  height: 16rpx;
}

/* ===== 空状态 - 呼吸感设计 ===== */

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 48rpx;
  background: rgba(255, 255, 255, 0.5);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-radius: var(--radius-2xl);
  border: 2px dashed rgba(139, 108, 246, 0.2);
  box-shadow: var(--shadow-glass-sm);
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: var(--spacing-xl);
  opacity: 0.5;
}

.empty-title {
  font-size: var(--font-2xl);
  font-weight: 600;
  color: var(--color-text-title);
  margin-bottom: var(--spacing-sm);
}

.empty-desc {
  font-size: var(--font-md);
  color: var(--color-text-secondary);
  text-align: center;
  line-height: 1.6;
}

/* ===== 滚动条隐藏 ===== */

::-webkit-scrollbar {
  display: none;
  width: 0;
  height: 0;
  color: transparent;
}

/* ===== 动画系统 v2.0 - 呼吸感与科技感 ===== */

/* 呼吸动画 - 用于强调元素 */
@keyframes breathe {
  0%, 100% { 
    transform: scale(1); 
    opacity: 1; 
  }
  50% { 
    transform: scale(1.03); 
    opacity: 0.92; 
  }
}

.breathe-animation {
  animation: breathe 3s cubic-bezier(0.4, 0, 0.6, 1) infinite;
}

/* 快速呼吸动画 */
@keyframes breathe-fast {
  0%, 100% { transform: scale(1); opacity: 1; }
  50% { transform: scale(1.05); opacity: 0.88; }
}

.breathe-fast {
  animation: breathe-fast 1.5s ease-in-out infinite;
}

/* 脉冲发光动画 - 用于加载/等待状态 */
@keyframes pulse-glow {
  0%, 100% { 
    box-shadow: 0 4px 16px rgba(139, 108, 246, 0.2); 
    transform: scale(1);
  }
  50% { 
    box-shadow: 0 4px 32px rgba(139, 108, 246, 0.45); 
    transform: scale(1.02);
  }
}

.pulse-glow {
  animation: pulse-glow 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
}

/* 浮动动画 - 用于卡片悬浮效果 */
@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-6rpx); }
}

.float-animation {
  animation: float 4s cubic-bezier(0.4, 0, 0.6, 1) infinite;
}

/* 缓慢浮动动画 */
@keyframes float-slow {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-3rpx); }
}

.float-slow {
  animation: float-slow 6s ease-in-out infinite;
}

/* 旋转动画 */
@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.spin-animation {
  animation: spin 1.5s linear infinite;
}

/* 慢速旋转 */
.spin-slow {
  animation: spin 4s linear infinite;
}

/* 淡入动画 */
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.fade-in {
  animation: fadeIn 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
}

/* 缩放进入动画 */
@keyframes scaleIn {
  from { opacity: 0; transform: scale(0.9); }
  to { opacity: 1; transform: scale(1); }
}

.scale-in {
  animation: scaleIn 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
}

/* 滑动进入动画 - 从左侧 */
@keyframes slideInLeft {
  from { opacity: 0; transform: translateX(-20rpx); }
  to { opacity: 1; transform: translateX(0); }
}

.slide-in-left {
  animation: slideInLeft 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
}

/* 滑动进入动画 - 从右侧 */
@keyframes slideInRight {
  from { opacity: 0; transform: translateX(20rpx); }
  to { opacity: 1; transform: translateX(0); }
}

.slide-in-right {
  animation: slideInRight 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
}

/* 滑动进入动画 - 从底部 */
@keyframes slideInUp {
  from { opacity: 0; transform: translateY(30rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.slide-in-up {
  animation: slideInUp 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
}

/* 骨架屏闪烁动画 */
@keyframes skeleton-shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}

.skeleton {
  background: linear-gradient(
    90deg,
    rgba(139, 108, 246, 0.08) 0%,
    rgba(139, 108, 246, 0.15) 50%,
    rgba(139, 108, 246, 0.08) 100%
  );
  background-size: 200% 100%;
  animation: skeleton-shimmer 1.5s ease-in-out infinite;
  border-radius: var(--radius-sm);
}

/* ===== 输入框系统 ===== */

.input-field {
  width: 100%;
  height: 96rpx;
  padding: 0 var(--spacing-xl);
  background: rgba(245, 243, 250, 0.7);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid rgba(237, 232, 254, 0.5);
  border-radius: var(--radius-capsule);
  font-size: var(--font-xl);
  color: var(--color-text-body);
  transition: all 0.25s ease;
}

.input-field:focus {
  background: rgba(255, 255, 255, 0.9);
  border-color: rgba(139, 108, 246, 0.4);
  box-shadow: 
    0 4px 16px rgba(139, 108, 246, 0.1),
    inset 0 1px 0 rgba(255, 255, 255, 0.8);
}

.input-field::placeholder {
  color: var(--color-text-placeholder);
}

/* ===== 徽章/角标系统 ===== */

.badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 10rpx;
  background: var(--color-danger);
  color: #fff;
  font-size: var(--font-xs);
  font-weight: 600;
  border-radius: var(--radius-capsule);
  box-shadow: 0 2px 8px rgba(255, 59, 48, 0.3);
}

.badge-primary {
  background: var(--color-primary);
  box-shadow: 0 2px 8px rgba(139, 108, 246, 0.3);
}

.badge-success {
  background: var(--color-success);
  box-shadow: 0 2px 8px rgba(52, 199, 89, 0.3);
}

.badge-warning {
  background: var(--color-warning);
  box-shadow: 0 2px 8px rgba(255, 149, 0, 0.3);
}

/* 红点徽章 */
.badge-dot {
  width: 16rpx;
  height: 16rpx;
  min-width: 16rpx;
  background: var(--color-danger);
  border-radius: 50%;
  box-shadow: 0 2px 6px rgba(255, 59, 48, 0.4);
}

/* ===== 工具类 ===== */

/* 文本截断 */
.text-truncate {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 多行文本截断 */
.text-truncate-2 {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.text-truncate-3 {
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* 弹性布局工具 */
.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-start {
  display: flex;
  align-items: center;
  justify-content: flex-start;
}

/* 隐藏元素 */
.hidden {
  display: none !important;
}

/* 可见性隐藏 */
.invisible {
  visibility: hidden;
}

/* 性能优化提示 */
.will-change-transform {
  will-change: transform;
}

.will-change-opacity {
  will-change: opacity;
}
