.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 110rpx;
  background: rgba(247, 245, 255, 0.94);
  backdrop-filter: blur(28px);
  -webkit-backdrop-filter: blur(28px);
  border-top: 1rpx solid rgba(237, 232, 254, 0.7);
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 999;
  box-shadow: 0 -4px 20px rgba(139, 108, 246, 0.06);
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 40rpx;
  border-radius: 16rpx;
}

.tab-icon {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 4rpx;
}

/* CSS-only home icon */
.icon-home {
  position: relative;
  width: 36rpx;
  height: 32rpx;
}
.home-roof {
  width: 0;
  height: 0;
  border-left: 18rpx solid transparent;
  border-right: 18rpx solid transparent;
  border-bottom: 16rpx solid #9999AA;
  position: absolute;
  top: 0;
  left: 0;
}
.home-body {
  width: 28rpx;
  height: 16rpx;
  border: 3rpx solid #9999AA;
  border-top: none;
  position: absolute;
  bottom: 0;
  left: 4rpx;
  border-radius: 0 0 4rpx 4rpx;
}

.tab-icon.active .home-roof {
  border-bottom-color: #8B6CF6;
}
.tab-icon.active .home-body {
  border-color: #8B6CF6;
  background: rgba(139, 108, 246, 0.15);
}

/* CSS-only user icon */
.icon-user {
  position: relative;
  width: 36rpx;
  height: 36rpx;
}
.user-head {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  border: 3rpx solid #9999AA;
  position: absolute;
  top: 2rpx;
  left: 50%;
  transform: translateX(-50%);
}
.user-body {
  width: 26rpx;
  height: 12rpx;
  border: 3rpx solid #9999AA;
  border-bottom: none;
  border-radius: 26rpx 26rpx 0 0;
  position: absolute;
  bottom: 2rpx;
  left: 50%;
  transform: translateX(-50%);
}

.tab-icon.active .user-head {
  border-color: #8B6CF6;
  background: rgba(139, 108, 246, 0.15);
}
.tab-icon.active .user-body {
  border-color: #8B6CF6;
}

.tab-text {
  font-size: 20rpx;
  color: #9999AA;
  font-weight: 400;
}
.tab-text.active {
  color: #8B6CF6;
  font-weight: 600;
}

/* Create button */
.tab-create {
  display: flex;
  flex-direction: column;
  align-items: center;
}
.create-btn {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #8B6CF6, #B49DFB);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6px 20px rgba(139, 108, 246, 0.42), inset 0 1px 0 rgba(255,255,255,0.2);
  margin-top: -36rpx;
  margin-bottom: 4rpx;
}
.create-icon {
  color: #fff;
  font-size: 44rpx;
  font-weight: 300;
  line-height: 1;
}
.create-text {
  font-size: 20rpx;
  color: #8B6CF6;
  font-weight: 600;
}

/* Sheet overlay */
.sheet-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(26, 26, 46, 0.55);
  z-index: 1000;
  opacity: 0;
  pointer-events: none;
  transition: opacity 300ms;
}
.sheet-mask.show {
  opacity: 1;
  pointer-events: auto;
}

.sheet-panel {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(247, 245, 255, 0.98);
  backdrop-filter: blur(24px);
  border-radius: 32rpx 32rpx 0 0;
  padding: 24rpx 24rpx 48rpx;
  z-index: 1001;
  transform: translateY(100%);
  transition: transform 300ms cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 -4px 40px rgba(139, 108, 246, 0.18);
}
.sheet-panel.show {
  transform: translateY(0);
}

.sheet-handle {
  width: 72rpx;
  height: 8rpx;
  background: #D4C8FD;
  border-radius: 4rpx;
  margin: 0 auto 24rpx;
}

.sheet-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.sheet-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #1A1A2E;
  display: block;
}

.sheet-sub {
  font-size: 24rpx;
  color: #9999AA;
  display: block;
  margin-top: 4rpx;
}

.sheet-close {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #EDE8FE;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8B6CF6;
  font-size: 28rpx;
}

.sheet-option {
  display: flex;
  align-items: center;
  padding: 28rpx;
  background: #FFFFFF;
  border: 1rpx solid #E8E8F0;
  border-radius: 24rpx;
  margin-bottom: 16rpx;
}

.sheet-option:active {
  background: #FAF8FF;
}

.option-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  flex-shrink: 0;
  margin-right: 24rpx;
}
.ai-icon {
  background: rgba(139, 108, 246, 0.12);
}
.form-icon {
  background: #F7F5FF;
}

.option-info {
  flex: 1;
}
.option-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #1A1A2E;
  display: flex;
  align-items: center;
}
.option-badge {
  font-size: 18rpx;
  font-weight: 700;
  color: #fff;
  background: linear-gradient(135deg, #8B6CF6, #B49DFB);
  padding: 4rpx 14rpx;
  border-radius: 40rpx;
  margin-right: 12rpx;
}
.option-desc {
  font-size: 24rpx;
  color: #9999AA;
  display: block;
  margin-top: 4rpx;
}
.option-arrow {
  color: #C4B5FD;
  font-size: 32rpx;
}
