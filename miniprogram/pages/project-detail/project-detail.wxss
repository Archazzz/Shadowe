/* Project Detail - iOS Liquid Glass Style v2.0 */
.detail-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #0F0F1A 0%, #1A1A3E 50%, #0F0F1A 100%);
  position: relative;
  overflow-x: hidden;
}

/* Ambient Background */
.detail-page::before {
  content: '';
  position: fixed;
  top: -20%;
  right: -10%;
  width: 600rpx;
  height: 600rpx;
  background: radial-gradient(circle, rgba(139,108,246,0.15) 0%, transparent 70%);
  border-radius: 50%;
  filter: blur(80px);
  pointer-events: none;
  animation: ambient-pulse 8s ease-in-out infinite;
}

@keyframes ambient-pulse {
  0%, 100% { opacity: 0.4; transform: scale(1); }
  50% { opacity: 0.6; transform: scale(1.1); }
}

/* Custom Nav - Liquid Glass */
.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: linear-gradient(180deg, 
    rgba(15,15,26,0.85) 0%, 
    rgba(26,26,62,0.75) 100%);
  backdrop-filter: blur(40px);
  -webkit-backdrop-filter: blur(40px);
  border-bottom: 1rpx solid rgba(180,157,251,0.15);
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,0.3);
}

.nav-bar {
  padding: 12rpx 24rpx 12rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 44px;
  box-sizing: border-box;
}

.nav-back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: background 0.2s ease;
}

.nav-back:active {
  background: rgba(180,157,251,0.15);
}

.nav-arrow {
  font-size: 40rpx;
  color: #B49DFB;
  font-weight: 500;
}

.nav-title {
  font-size: 32rpx;
  font-weight: 600;
  background: linear-gradient(135deg, #FFFFFF 0%, #E0D4FC 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  flex: 1;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.nav-more {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: background 0.2s ease;
}

.nav-more:active {
  background: rgba(180,157,251,0.15);
}

.nav-more-icon {
  font-size: 40rpx;
  color: rgba(180,157,251,0.8);
  letter-spacing: 2rpx;
}

/* Content Scroll */
.content-scroll {
  padding: 24rpx 24rpx 0;
  box-sizing: border-box;
}

/* Overview Card - Liquid Glass */
.overview-card {
  background: linear-gradient(135deg, 
    rgba(255,255,255,0.08) 0%, 
    rgba(255,255,255,0.04) 100%);
  backdrop-filter: blur(32px);
  -webkit-backdrop-filter: blur(32px);
  border: 2rpx solid rgba(180,157,251,0.2);
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 
    0 12rpx 40rpx rgba(0,0,0,0.25),
    inset 0 2rpx 10rpx rgba(255,255,255,0.1);
  display: flex;
  align-items: center;
}

.overview-ring {
  margin-right: 40rpx;
  flex-shrink: 0;
}

/* Progress Ring - Canvas */
.ring-container {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  flex-shrink: 0;
}

.ring-canvas {
  width: 160rpx;
  height: 160rpx;
}

.ring-inner {
  position: absolute;
  top: 24rpx;
  left: 24rpx;
  right: 24rpx;
  bottom: 24rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, 
    rgba(139,108,246,0.15) 0%, 
    rgba(180,157,251,0.08) 100%);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 2rpx solid rgba(180,157,251,0.25);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 
    inset 0 4rpx 16rpx rgba(0,0,0,0.15),
    0 4rpx 12rpx rgba(139,108,246,0.2);
}

.ring-pct {
  font-size: 36rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #B49DFB 0%, #FFFFFF 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  line-height: 1.1;
}

.ring-label {
  font-size: 20rpx;
  color: rgba(180,157,251,0.7);
  margin-top: 4rpx;
}

/* Stats */
.overview-stats {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-around;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #FFFFFF 0%, #E0D4FC 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  line-height: 1.1;
  margin-bottom: 6rpx;
}

.stat-value--success {
  background: linear-gradient(135deg, #34C759 0%, #2ECC71 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.stat-value--pending {
  background: linear-gradient(135deg, rgba(180,157,251,0.6) 0%, rgba(180,157,251,0.4) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.stat-label {
  font-size: 22rpx;
  color: rgba(180,157,251,0.7);
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: linear-gradient(180deg, 
    transparent 0%, 
    rgba(180,157,251,0.3) 50%, 
    transparent 100%);
}

/* Section Header */
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
  padding: 0 8rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  background: linear-gradient(135deg, #FFFFFF 0%, #E0D4FC 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.section-count {
  font-size: 24rpx;
  color: rgba(180,157,251,0.6);
}

/* Material Cards - Liquid Glass */
.material-list {
  display: flex;
  flex-direction: column;
}

.material-card {
  background: linear-gradient(135deg, 
    rgba(255,255,255,0.06) 0%, 
    rgba(255,255,255,0.03) 100%);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  border: 2rpx solid rgba(180,157,251,0.15);
  border-radius: 28rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  box-shadow: 
    0 8rpx 24rpx rgba(0,0,0,0.2),
    inset 0 1rpx 6rpx rgba(255,255,255,0.08);
  margin-bottom: 16rpx;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.material-card:last-child {
  margin-bottom: 0;
}

.material-card:active {
  transform: scale(0.98);
  background: linear-gradient(135deg, 
    rgba(255,255,255,0.1) 0%, 
    rgba(255,255,255,0.05) 100%);
  border-color: rgba(180,157,251,0.25);
}

.material-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, 
    rgba(139,108,246,0.2) 0%, 
    rgba(180,157,251,0.1) 100%);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border: 2rpx solid rgba(180,157,251,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 20rpx;
  box-shadow: 
    0 4rpx 12rpx rgba(139,108,246,0.2),
    inset 0 2rpx 6rpx rgba(255,255,255,0.1);
}

.material-icon {
  font-size: 36rpx;
}

.material-info {
  flex: 1;
  min-width: 0;
}

.material-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #FFFFFF;
  display: block;
  margin-bottom: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.material-meta {
  font-size: 22rpx;
  color: rgba(180,157,251,0.65);
  display: flex;
  flex-direction: row;
  align-items: center;
  flex-wrap: wrap;
}

/* Status badges */
.material-status {
  border-radius: 40rpx;
  padding: 6rpx 16rpx;
  flex-shrink: 0;
  margin-left: 12rpx;
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
}

.status-completed {
  background: rgba(52,199,89,0.15);
  border: 1rpx solid rgba(52,199,89,0.3);
}

.status-analyzing {
  background: rgba(255,149,0,0.15);
  border: 1rpx solid rgba(255,149,0,0.3);
}

.status-pending {
  background: rgba(153,153,170,0.15);
  border: 1rpx solid rgba(153,153,170,0.3);
}

.status-text {
  font-size: 20rpx;
  font-weight: 500;
  white-space: nowrap;
}

.status-completed .status-text {
  color: #34C759;
  text-shadow: 0 2rpx 8rpx rgba(52,199,89,0.3);
}

.status-analyzing .status-text {
  color: #FF9500;
  text-shadow: 0 2rpx 8rpx rgba(255,149,0,0.3);
}

.status-pending .status-text {
  color: rgba(180,157,251,0.7);
}

/* Empty State */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  filter: drop-shadow(0 4rpx 12rpx rgba(139,108,246,0.3));
}

.empty-text {
  font-size: 30rpx;
  color: rgba(255,255,255,0.8);
  font-weight: 500;
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: rgba(180,157,251,0.6);
}

/* FAB Overlay */
.fab-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.4);
  backdrop-filter: blur(4px);
  -webkit-backdrop-filter: blur(4px);
  z-index: 90;
}

/* FAB Menu - Liquid Glass */
.fab-menu {
  position: fixed;
  bottom: 180rpx;
  right: 40rpx;
  z-index: 100;
  display: flex;
  flex-direction: column;
  animation: fabMenuIn 250ms cubic-bezier(0.4, 0, 0.2, 1);
}

@keyframes fabMenuIn {
  from {
    opacity: 0;
    transform: translateY(20rpx) scale(0.95);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

.fab-menu-item {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, 
    rgba(255,255,255,0.12) 0%, 
    rgba(255,255,255,0.06) 100%);
  backdrop-filter: blur(32px);
  -webkit-backdrop-filter: blur(32px);
  border: 2rpx solid rgba(180,157,251,0.2);
  border-radius: 60rpx;
  padding: 16rpx 28rpx 16rpx 16rpx;
  box-shadow: 
    0 8rpx 24rpx rgba(0,0,0,0.3),
    inset 0 2rpx 8rpx rgba(255,255,255,0.15);
  position: relative;
  margin-bottom: 16rpx;
  transition: all 0.2s ease;
}

.fab-menu-item:last-child {
  margin-bottom: 0;
}

.fab-menu-item:active {
  transform: scale(0.95);
  background: linear-gradient(135deg, 
    rgba(255,255,255,0.18) 0%, 
    rgba(255,255,255,0.1) 100%);
}

.fab-menu-item--new {
  border-color: rgba(255,107,157,0.4);
}

.fab-menu-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, 
    rgba(139,108,246,0.25) 0%, 
    rgba(180,157,251,0.15) 100%);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border: 2rpx solid rgba(180,157,251,0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  margin-right: 16rpx;
  box-shadow: 
    0 4rpx 12rpx rgba(139,108,246,0.25),
    inset 0 2rpx 6rpx rgba(255,255,255,0.1);
}

.fab-menu-label {
  font-size: 26rpx;
  font-weight: 500;
  color: #FFFFFF;
}

.fab-new-badge {
  position: absolute;
  top: -6rpx;
  right: -6rpx;
  background: linear-gradient(135deg, #FF6B9D 0%, #FF8FAB 100%);
  color: #FFFFFF;
  font-size: 16rpx;
  font-weight: 700;
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
  box-shadow: 0 4rpx 12rpx rgba(255,107,157,0.4);
}

/* FAB Button - Liquid Glass Orb */
.fab-btn {
  position: fixed;
  bottom: 80rpx;
  right: 40rpx;
  width: 108rpx;
  height: 108rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, 
    #8B6CF6 0%, 
    #A78BFA 45%, 
    #B49DFB 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 
    0 12rpx 40rpx rgba(139,108,246,0.5),
    inset 0 3rpx 0 rgba(255,255,255,0.3),
    inset 0 -3rpx 0 rgba(0,0,0,0.1);
  z-index: 100;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
}

.fab-btn::before {
  content: '';
  position: absolute;
  top: 15%;
  left: 20%;
  width: 50%;
  height: 25%;
  border-radius: 50%;
  background: linear-gradient(180deg, rgba(255,255,255,0.5) 0%, rgba(255,255,255,0.1) 100%);
  filter: blur(6rpx);
}

.fab-btn:active {
  transform: scale(0.92);
  box-shadow: 
    0 6rpx 20rpx rgba(139,108,246,0.4),
    inset 0 2rpx 0 rgba(255,255,255,0.2);
}

.fab-icon {
  font-size: 48rpx;
  color: #FFFFFF;
  font-weight: 300;
  line-height: 1;
  z-index: 1;
  text-shadow: 0 4rpx 12rpx rgba(0,0,0,0.2);
}
