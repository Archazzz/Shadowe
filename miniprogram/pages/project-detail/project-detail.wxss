/* pages/project-detail/project-detail.wxss */
.detail-page {
  min-height: 100vh;
  background: #F7F5FF;
  position: relative;
  overflow-x: hidden;
}

/* Custom Nav */
.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: rgba(247, 245, 255, 0.95);
  border-bottom: 1rpx solid rgba(237, 232, 254, 0.7);
}

/* Nav Bar */
.nav-bar {
  padding: 12rpx 24rpx 12rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 44px;
  box-sizing: border-box;
}

.nav-back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-arrow {
  font-size: 40rpx;
  color: #1A1A2E;
  font-weight: 500;
}

.nav-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A2E;
  flex: 1;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.nav-more {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-more-icon {
  font-size: 40rpx;
  color: #666677;
  letter-spacing: 2rpx;
}

/* Content Scroll - use regular view, page scrolls natively */
.content-scroll {
  padding: 24rpx 24rpx 0;
  box-sizing: border-box;
}

/* Overview Card */
.overview-card {
  background: #FFFFFF;
  border: 1rpx solid #EDE8FE;
  border-radius: 28rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 2px 12px rgba(139, 108, 246, 0.07);
  display: flex;
  align-items: center;
}

.overview-ring {
  margin-right: 40rpx;
  flex-shrink: 0;
}

/* Progress Ring - Canvas */
.ring-container {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  flex-shrink: 0;
}

.ring-canvas {
  width: 160rpx;
  height: 160rpx;
}

.ring-inner {
  position: absolute;
  top: 24rpx;
  left: 24rpx;
  right: 24rpx;
  bottom: 24rpx;
  border-radius: 50%;
  background: #FFFFFF;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.ring-pct {
  font-size: 36rpx;
  font-weight: 700;
  color: #8B6CF6;
  line-height: 1.1;
}

.ring-label {
  font-size: 20rpx;
  color: #9999AA;
  margin-top: 4rpx;
}

/* Stats */
.overview-stats {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: space-around;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #1A1A2E;
  line-height: 1.1;
  margin-bottom: 6rpx;
}

.stat-value--success {
  color: #34C759;
}

.stat-value--pending {
  color: #9999AA;
}

.stat-label {
  font-size: 22rpx;
  color: #666677;
}

.stat-divider {
  width: 1rpx;
  height: 60rpx;
  background: #E8E8F0;
}

/* Section Header */
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1A1A2E;
}

.section-count {
  font-size: 24rpx;
  color: #9999AA;
}

/* Material Cards */
.material-list {
  display: flex;
  flex-direction: column;
}

.material-card {
  background: #FFFFFF;
  border: 1rpx solid #EDE8FE;
  border-radius: 24rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 2px 8px rgba(139, 108, 246, 0.06);
  margin-bottom: 16rpx;
}

.material-card:last-child {
  margin-bottom: 0;
}

.material-card:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.material-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #EDE8FE;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 20rpx;
}

.material-icon {
  font-size: 36rpx;
}

.material-info {
  flex: 1;
  min-width: 0;
}

.material-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A2E;
  display: block;
  margin-bottom: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.material-meta {
  font-size: 22rpx;
  color: #9999AA;
  display: flex;
  flex-direction: row;
  align-items: center;
  flex-wrap: wrap;
}

/* Status badges - use classes instead of inline styles for compatibility */
.material-status {
  border-radius: 40rpx;
  padding: 6rpx 16rpx;
  flex-shrink: 0;
  margin-left: 12rpx;
}

.status-completed {
  background: rgba(52, 199, 89, 0.1);
}

.status-analyzing {
  background: rgba(255, 149, 0, 0.1);
}

.status-pending {
  background: rgba(153, 153, 170, 0.1);
}

.status-text {
  font-size: 20rpx;
  font-weight: 500;
  white-space: nowrap;
}

.status-completed .status-text {
  color: #34C759;
}

.status-analyzing .status-text {
  color: #FF9500;
}

.status-pending .status-text {
  color: #9999AA;
}

/* Empty State */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #666677;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #9999AA;
}

/* FAB Overlay */
.fab-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(26, 26, 46, 0.3);
  z-index: 90;
}

/* FAB Menu */
.fab-menu {
  position: fixed;
  bottom: 180rpx;
  right: 40rpx;
  z-index: 100;
  display: flex;
  flex-direction: column;
  animation: fabMenuIn 250ms ease-out;
}

@keyframes fabMenuIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.fab-menu-item {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.95);
  border: 1rpx solid #EDE8FE;
  border-radius: 60rpx;
  padding: 16rpx 28rpx 16rpx 16rpx;
  box-shadow: 0 4px 16px rgba(139, 108, 246, 0.15);
  position: relative;
  margin-bottom: 16rpx;
}

.fab-menu-item:last-child {
  margin-bottom: 0;
}

.fab-menu-item:active {
  transform: scale(0.95);
}

.fab-menu-item--new {
  border-color: rgba(255, 107, 157, 0.3);
}

.fab-menu-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #EDE8FE;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  margin-right: 16rpx;
}

.fab-menu-label {
  font-size: 26rpx;
  font-weight: 500;
  color: #1A1A2E;
}

.fab-new-badge {
  position: absolute;
  top: -6rpx;
  right: -6rpx;
  background: #FF6B9D;
  color: #FFFFFF;
  font-size: 16rpx;
  font-weight: 700;
  padding: 2rpx 10rpx;
  border-radius: 8rpx;
}

/* FAB Button */
.fab-btn {
  position: fixed;
  bottom: 80rpx;
  right: 40rpx;
  width: 108rpx;
  height: 108rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #8B6CF6, #B49DFB);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8px 24px rgba(139, 108, 246, 0.35);
  z-index: 100;
  transition: transform 200ms ease;
}

.fab-btn:active {
  transform: scale(0.92);
}

.fab-icon {
  font-size: 48rpx;
  color: #FFFFFF;
  font-weight: 300;
  line-height: 1;
}
