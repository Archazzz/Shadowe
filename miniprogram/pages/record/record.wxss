/* 访谈记录页 - iOS 液态玻璃风格 */
.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #F7F5FF 0%, #EDE8FE 100%);
  display: flex;
  flex-direction: column;
  overflow-x: hidden;
  position: relative;
}

/* 环境光晕 */
.page::before {
  content: '';
  position: absolute;
  top: -200rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 600rpx;
  height: 600rpx;
  background: radial-gradient(circle, rgba(139, 108, 246, 0.1) 0%, transparent 70%);
  pointer-events: none;
  z-index: 0;
}

/* Custom Nav - 液态玻璃 */
.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: rgba(247, 245, 255, 0.85);
  backdrop-filter: blur(32px) saturate(180%);
  -webkit-backdrop-filter: blur(32px) saturate(180%);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.3);
  box-shadow: 0 4px 24rpx rgba(139, 108, 246, 0.06);
}

.nav-status {
  width: 100%;
}

.nav-bar {
  padding: 16rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: sticky;
  top: 0;
  z-index: 10;
}

.nav-left {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.5);
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.nav-left:active {
  background: rgba(139, 108, 246, 0.15);
  transform: scale(0.95);
}

.nav-icon {
  font-size: 36rpx;
  color: #1A1A2E;
}

.nav-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1A1A2E;
  letter-spacing: 1rpx;
}

.nav-right {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.5);
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.nav-right:active {
  background: rgba(139, 108, 246, 0.15);
  transform: scale(0.95);
}

/* Content Scroll */
.content-scroll {
  padding: 16rpx 32rpx;
  padding-top: calc(var(--status-bar-height, 20px) + 88rpx + 16rpx);
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  overflow-x: hidden;
  position: relative;
  z-index: 1;
  flex: 1;
}

/* Info Card - 液态玻璃卡片 */
.info-card {
  background: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(24px);
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8px 32rpx rgba(139, 108, 246, 0.08), inset 0 1rpx 0 rgba(255,255,255,0.8);
}

.info-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.info-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #8B6CF6, #B49DFB);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #fff;
  flex-shrink: 0;
  margin-right: 20rpx;
  box-shadow: 0 4px 20rpx rgba(139, 108, 246, 0.3), inset 0 1rpx 0 rgba(255,255,255,0.2);
}

.info-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #1A1A2E;
  margin-bottom: 6rpx;
}

.info-meta {
  display: flex;
  align-items: center;
}

.meta-item {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #666677;
  margin-right: 24rpx;
}

.meta-item:last-child {
  margin-right: 0;
}

.meta-icon {
  font-size: 24rpx;
  margin-right: 6rpx;
}

/* Transcript List */
.transcript-list {
  display: flex;
  flex-direction: column;
}

.transcript-item {
  background: rgba(255, 255, 255, 0.5);
  backdrop-filter: blur(16px);
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  border-radius: 28rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4px 20rpx rgba(139, 108, 246, 0.06);
  transition: all 0.2s ease;
}

.transcript-item:active {
  transform: scale(0.98);
}

.transcript-item:last-child {
  margin-bottom: 0;
}

.item-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.item-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(237, 232, 254, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #8B6CF6;
  flex-shrink: 0;
  margin-right: 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.6);
}

.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.item-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #1A1A2E;
  margin-bottom: 4rpx;
}

.item-time {
  font-size: 22rpx;
  color: #9999AA;
}

.item-type {
  padding: 6rpx 20rpx;
  border-radius: 40rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.type-interviewer {
  background: rgba(139, 108, 246, 0.1);
  color: #8B6CF6;
  border: 1rpx solid rgba(139, 108, 246, 0.2);
}

.type-interviewee {
  background: rgba(52, 199, 89, 0.1);
  color: #34C759;
  border: 1rpx solid rgba(52, 199, 89, 0.2);
}

.item-text {
  font-size: 28rpx;
  color: #333344;
  line-height: 1.6;
  display: block;
}

/* Audio Player Bar - 液态玻璃播放器 */
.audio-player-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(247, 245, 255, 0.85);
  backdrop-filter: blur(32px) saturate(180%);
  -webkit-backdrop-filter: blur(32px) saturate(180%);
  border-top: 1rpx solid rgba(255, 255, 255, 0.4);
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4px 24rpx rgba(139, 108, 246, 0.06);
  z-index: 100;
  transform: translateY(100%);
  transition: transform 300ms cubic-bezier(0.4, 0, 0.2, 1);
}

.audio-player-bar.show {
  transform: translateY(0);
}

.player-row {
  display: flex;
  align-items: center;
}

.player-controls {
  display: flex;
  align-items: center;
  margin-right: 24rpx;
}

.player-play-btn {
  width: 84rpx;
  height: 84rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #8B6CF6, #B49DFB);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 4px 20rpx rgba(139, 108, 246, 0.35), inset 0 1rpx 0 rgba(255,255,255,0.2);
  transition: all 0.2s ease;
}

.player-play-btn:active {
  transform: scale(0.95);
  box-shadow: 0 4px 16rpx rgba(139, 108, 246, 0.25);
}

.play-icon {
  font-size: 36rpx;
  color: #fff;
}

.player-info {
  flex: 1;
  margin-right: 24rpx;
}

.player-status {
  font-size: 24rpx;
  color: #666677;
  margin-bottom: 10rpx;
  display: block;
}

.player-progress-track {
  background: rgba(237, 232, 254, 0.6);
  border-radius: 6rpx;
  height: 8rpx;
  overflow: hidden;
}

.player-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #8B6CF6, #B49DFB);
  border-radius: 6rpx;
  transition: width 200ms linear;
  box-shadow: 0 1px 4rpx rgba(139, 108, 246, 0.2);
}

.player-close {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.5);
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.2s ease;
}

.player-close:active {
  background: rgba(139, 108, 246, 0.15);
  transform: scale(0.95);
}

.close-icon {
  font-size: 28rpx;
  color: #666677;
}
