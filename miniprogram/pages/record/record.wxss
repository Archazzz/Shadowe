.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #1A1A2E, #2D2D45);
  display: flex;
  flex-direction: column;
  padding-bottom: env(safe-area-inset-bottom);
}

/* Custom Header */
.custom-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
}

.header-status {
  width: 100%;
}

/* Header */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx;
  padding-top: calc(env(safe-area-inset-top) + 24rpx);
  height: 88rpx;
}

.header-left {
  width: 80rpx;
  display: flex;
  align-items: center;
}

.back-arrow {
  width: 40rpx;
  height: 40rpx;
}

.header-center {
  display: flex;
  align-items: center;
}

.brand-logo {
  width: 40rpx;
  height: 40rpx;
  margin-right: 12rpx;
}

.brand-text {
  font-size: 32rpx;
  font-weight: 500;
  color: #FFFFFF;
  letter-spacing: 2rpx;
}

.header-right {
  width: 80rpx;
  display: flex;
  justify-content: flex-end;
  align-items: center;
}

.recording-status-wrap {
  display: flex;
  align-items: center;
}

.red-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #FF3B30;
  animation: pulse-dot 1.2s ease-in-out infinite;
  margin-right: 10rpx;
}

.recording-status-text {
  font-size: 22rpx;
  font-weight: 500;
}

.status-recording {
  color: #FF6B6B;
}

.status-paused {
  color: rgba(255,255,255,0.4);
}

@keyframes pulse-dot {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.5; transform: scale(1.3); }
}

/* Timer */
.timer-section {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.timer {
  font-size: 108rpx;
  font-weight: 200;
  color: #FFFFFF;
  font-variant-numeric: tabular-nums;
  letter-spacing: 4rpx;
}

.timer-subtitle {
  font-size: 24rpx;
  color: rgba(180,157,251,0.55);
  margin-top: 8rpx;
  letter-spacing: 2rpx;
}

/* Waveform Section */
.waveform-section {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  margin: 40rpx 0;
  position: relative;
}

.ripple-container {
  position: relative;
  width: 400rpx;
  height: 400rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.ripple {
  position: absolute;
  border-radius: 50%;
  border: 2rpx solid rgba(139, 108, 246, 0.3);
  animation: ripple-expand 2.4s ease-out infinite;
}

.ripple-1 {
  width: 400rpx;
  height: 400rpx;
  animation-delay: 0s;
}

.ripple-2 {
  width: 480rpx;
  height: 480rpx;
  animation-delay: 0.8s;
}

.ripple-3 {
  width: 560rpx;
  height: 560rpx;
  animation-delay: 1.6s;
}

@keyframes ripple-expand {
  0% {
    transform: scale(0.7);
    opacity: 0.6;
  }
  100% {
    transform: scale(1.3);
    opacity: 0;
  }
}

.waveform-circle {
  width: 320rpx;
  height: 320rpx;
  border-radius: 50%;
  background: rgba(139, 108, 246, 0.08);
  border: 2rpx solid rgba(139, 108, 246, 0.2);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 2;
}

.wave-bars {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 200rpx;
}

.wave-bar {
  width: 6rpx;
  border-radius: 3rpx;
  background: linear-gradient(180deg, rgba(180, 157, 251, 0.9), rgba(139, 108, 246, 0.5));
  transition: height 120ms ease;
  min-height: 8rpx;
  margin-right: 8rpx;
}

.wave-bar:last-child {
  margin-right: 0;
}

/* Controls */
.controls {
  display: flex;
  justify-content: center;
  align-items: center;
  margin: 20rpx 0 40rpx;
}

.control-btn {
  display: flex;
  justify-content: center;
  align-items: center;
  border-radius: 50%;
  margin-right: 64rpx;
}

.control-btn:last-child {
  margin-right: 0;
}

.control-bookmark {
  width: 108rpx;
  height: 108rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.08);
  border: 1.5rpx solid rgba(180,157,251,0.25);
  backdrop-filter: blur(12rpx);
}

.bookmark-icon {
  display: flex;
  justify-content: center;
  align-items: center;
}

.bookmark-text {
  font-size: 22rpx;
  color: #B49DFB;
  font-weight: 500;
}

.control-main {
  width: 148rpx;
  height: 148rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(255,255,255,0.18), rgba(255,255,255,0.08));
  border: 1.5rpx solid rgba(255,255,255,0.2);
  backdrop-filter: blur(16px);
  box-shadow: 0 4px 24rpx rgba(0,0,0,0.3), inset 0 1px 0 rgba(255,255,255,0.15);
}

.control-stop {
  width: 108rpx;
  height: 108rpx;
  border-radius: 50%;
  background: rgba(255,59,48,0.15);
  border: 1.5rpx solid rgba(255,59,48,0.35);
}

.stop-icon {
  width: 32rpx;
  height: 32rpx;
  background: #FF3B30;
  border-radius: 6rpx;
}

.pause-icon {
  display: flex;
  align-items: center;
}

.pause-bar {
  width: 10rpx;
  height: 36rpx;
  background: #FFFFFF;
  border-radius: 4rpx;
  margin-right: 8rpx;
}

.pause-bar:last-child {
  margin-right: 0;
}

.play-pause-icon {
  display: flex;
  justify-content: center;
  align-items: center;
}

.play-triangle {
  width: 0;
  height: 0;
  border-style: solid;
  border-width: 18rpx 0 18rpx 30rpx;
  border-color: transparent transparent transparent #FFFFFF;
  margin-left: 6rpx;
}

/* Markers Section */
.markers-section {
  margin: 0 32rpx 40rpx;
}

.markers-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  width: 100%;
  background: rgba(255,255,255,0.06);
  border: 1.5rpx solid rgba(180,157,251,0.15);
  border-radius: 28rpx;
  padding: 20rpx 32rpx;
  color: rgba(255,255,255,0.6);
  font-size: 26rpx;
  backdrop-filter: blur(12rpx);
}

.markers-title {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: rgba(255,255,255,0.65);
}

.markers-toggle {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  height: 48rpx;
  transition: transform 0.3s ease;
}

.markers-toggle.expanded {
  transform: rotate(90deg);
}

.toggle-arrow {
  font-size: 36rpx;
  color: rgba(180, 157, 251, 0.7);
}

.markers-list {
  margin-top: 16rpx;
  max-height: 300rpx;
  overflow-y: auto;
}

.marker-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(180, 157, 251, 0.1);
}

.marker-item:last-child {
  border-bottom: none;
}

.marker-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #8B6CF6;
  margin-right: 16rpx;
}

.marker-time {
  font-size: 26rpx;
  color: rgba(180, 157, 251, 0.7);
  font-variant-numeric: tabular-nums;
  min-width: 100rpx;
}

.marker-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
}

.markers-empty {
  margin-top: 24rpx;
  display: flex;
  justify-content: center;
  padding-bottom: 16rpx;
}

.empty-text {
  font-size: 24rpx;
  color: rgba(180, 157, 251, 0.5);
}
