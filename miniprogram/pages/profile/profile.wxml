<view class="page">
  <!-- Status Bar Spacer -->
  <view style="height: {{statusBarHeight}}px;"></view>

  <!-- Dark Gradient Header -->
  <view class="profile-header">
    <view class="header-bg"></view>
    <view class="header-content">
      <!-- User Info -->
      <view class="user-info">
        <view class="avatar-wrapper" bindtap="onEditProfile">
          <view class="avatar">
            <text class="avatar-icon">🤖</text>
          </view>
        </view>
        <view class="user-details">
          <text class="user-name">{{user.name || '研究员小李'}}</text>
          <text class="user-id">ID: {{user.id || 'u_001'}}</text>
        </view>
        <view class="plan-badge">
          <text class="plan-text">免费版</text>
        </view>
        <view class="edit-btn" bindtap="onEditProfile">
          <text class="edit-icon">✏️</text>
        </view>
      </view>
    </view>
  </view>

  <!-- Stats Row -->
  <view class="stats-card glass-card">
    <view class="stat-item" wx:for="{{stats}}" wx:key="label">
      <text class="stat-icon">{{item.icon}}</text>
      <text class="stat-value">{{item.value}}</text>
      <text class="stat-label">{{item.label}}</text>
    </view>
  </view>

  <!-- Menu Sections -->
  <view class="menu-sections">
    <view class="menu-section" wx:for="{{menuSections}}" wx:key="title">
      <text class="section-title">{{item.title}}</text>
      <view class="menu-list">
        <view class="menu-item" wx:for="{{item.items}}" wx:for-item="menuItem" wx:key="name" bindtap="onMenuItemTap" data-name="{{menuItem.name}}">
          <view class="menu-left">
            <view class="menu-icon-wrapper" style="background: {{menuItem.iconBg}}">
              <text class="menu-icon">{{menuItem.icon}}</text>
            </view>
            <text class="menu-name">{{menuItem.name}}</text>
          </view>
          <view class="menu-right">
            <view class="menu-badge {{menuItem.badgeType === 'recommend' ? 'badge-recommend' : menuItem.badgeType === 'active' ? 'badge-active' : ''}}" wx:if="{{menuItem.badge}}">
              <text>{{menuItem.badge}}</text>
            </view>
            <text class="menu-arrow">›</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- Branding Footer -->
  <view class="branding">
    <text class="branding-text">🤖 Shadowe 影察 · v1.1.0</text>
  </view>

  <!-- Logout -->
  <view class="logout-btn" bindtap="onLogout">
    <text class="logout-text">退出登录</text>
  </view>
</view>
