.page {
  min-height: 100vh;
  background: #F7F5FF;
}

/* Header */
.profile-header {
  position: relative;
  overflow: hidden;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(160deg, #2D1B69, #1A1A2E);
}

.header-content {
  position: relative;
  z-index: 1;
  padding: 0 32rpx;
  padding-top: calc(80rpx + env(safe-area-inset-top));
  padding-bottom: 40rpx;
}

/* User Info */
.user-info {
  display: flex;
  align-items: center;
}

.avatar-wrapper {
  flex-shrink: 0;
  margin-right: 20rpx;
}

.avatar {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #8B6CF6, #B49DFB);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  box-shadow: 0 4px 20px rgba(139, 108, 246, 0.4);
}

.avatar-icon {
  font-size: 56rpx;
}

.user-details {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 4rpx;
}

.user-id {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

.plan-badge {
  padding: 6rpx 20rpx;
  background: rgba(255, 255, 255, 0.15);
  border: 1rpx solid rgba(255, 255, 255, 0.25);
  border-radius: 40rpx;
  flex-shrink: 0;
}

.plan-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.9);
  font-weight: 500;
}

.edit-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.edit-icon {
  font-size: 28rpx;
}

/* Stats Card */
.stats-card {
  display: flex;
  margin: -24rpx 32rpx 0;
  position: relative;
  z-index: 2;
  padding: 32rpx 24rpx;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-icon {
  font-size: 36rpx;
  margin-bottom: 8rpx;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #1A1A2E;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 22rpx;
  color: #666677;
}

/* Menu Sections */
.menu-sections {
  padding: 32rpx;
}

.menu-section {
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #666677;
  margin-bottom: 16rpx;
  padding-left: 4rpx;
}

.menu-list {
  background: rgba(255, 255, 255, 0.85);
  border-radius: 24rpx;
  border: 1rpx solid #EDE8FE;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid #F0EDF8;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background: rgba(139, 108, 246, 0.03);
}

.menu-left {
  display: flex;
  align-items: center;
}

.menu-icon-wrapper {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.menu-icon {
  font-size: 36rpx;
}

.menu-name {
  font-size: 30rpx;
  color: #1A1A2E;
  font-weight: 500;
}

.menu-right {
  display: flex;
  align-items: center;
}

.menu-badge {
  padding: 4rpx 16rpx;
  border-radius: 40rpx;
  font-size: 22rpx;
  font-weight: 500;
  margin-right: 12rpx;
}

.badge-recommend {
  background: rgba(255, 149, 0, 0.12);
  color: #FF9500;
}

.badge-active {
  background: rgba(255, 107, 157, 0.12);
  color: #FF6B9D;
}

.menu-arrow {
  font-size: 36rpx;
  color: #CCCCCC;
  font-weight: 300;
}

/* Branding */
.branding {
  display: flex;
  justify-content: center;
  padding: 40rpx 0 24rpx;
}

.branding-text {
  font-size: 24rpx;
  color: #9999AA;
}

/* Logout */
.logout-btn {
  margin: 0 32rpx 40rpx;
  padding: 28rpx 0;
  border: 2rpx solid #FF3B30;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.logout-btn:active {
  background: rgba(255, 59, 48, 0.05);
}

.logout-text {
  font-size: 30rpx;
  font-weight: 500;
  color: #FF3B30;
}
