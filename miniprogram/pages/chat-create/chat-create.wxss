/* AI创建项目页 */
.page {
  min-height: 100vh;
  background-color: var(--color-bg);
  display: flex;
  flex-direction: column;
  overflow-x: hidden;
}

/* 自定义导航栏 */
.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: rgba(247, 245, 255, 0.90);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-bottom: 1px solid rgba(237, 232, 254, 0.6);
}

.nav-status {
  width: 100%;
}

.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 32rpx;
}

.nav-back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-back-icon {
  width: 40rpx;
  height: 40rpx;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--color-text-title);
}

.nav-skip {
  font-size: 26rpx;
  color: var(--color-primary);
  padding: 8rpx 16rpx;
}

/* 聊天区域 */
.chat-area {
  flex: 1;
  padding: calc(var(--status-bar-height, 20px) + 88rpx + 16rpx) 24rpx 16rpx;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom) + 16rpx);
  height: calc(100vh - 120rpx);
  box-sizing: border-box;
}

.chat-messages {
  padding-bottom: 32rpx;
}

/* 消息行 */
.message-row {
  display: flex;
  margin-bottom: 32rpx;
  align-items: flex-start;
}

.message-row--ai {
  justify-content: flex-start;
}

.message-row--user {
  justify-content: flex-end;
}

/* 头像 */
.avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
}

.avatar--ai {
  background: linear-gradient(135deg, #8B6CF6, #B49DFB);
  margin-right: 16rpx;
}

/* 消息内容 */
.message-content {
  max-width: 75%;
}

.message-content--ai {
  align-items: flex-start;
}

.message-content--user {
  align-items: flex-end;
}

/* 气泡 */
.bubble {
  padding: 20rpx 28rpx;
  font-size: 28rpx;
  line-height: 1.6;
  word-break: break-all;
}

.bubble--ai {
  background: var(--color-primary-faint);
  color: var(--color-text-body);
  border-radius: 4rpx 24rpx 24rpx 24rpx;
}

.bubble--user {
  background: linear-gradient(135deg, #8B6CF6, #B49DFB);
  color: #FFFFFF;
  border-radius: 24rpx 4rpx 24rpx 24rpx;
}

/* 快捷建议 */
.suggestions {
  display: flex;
  flex-wrap: wrap;
  margin-top: 16rpx;
}

.suggestion-tag {
  display: inline-flex;
  align-items: center;
  padding: 10rpx 24rpx;
  border: 1rpx solid var(--color-primary-pale);
  border-radius: var(--radius-capsule);
  font-size: 24rpx;
  color: var(--color-primary);
  background: rgba(255, 255, 255, 0.8);
  margin-right: 12rpx;
  margin-bottom: 12rpx;
}

.suggestion-tag:active {
  background: var(--color-primary-faint);
}

/* 正在输入指示器 */
.typing-bubble {
  padding: 24rpx 32rpx;
}

.typing-indicator {
  display: flex;
  align-items: center;
}

.typing-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--color-primary-light);
  animation: typing-bounce 1.4s infinite ease-in-out;
  margin-right: 8rpx;
}

.typing-dot:last-child {
  margin-right: 0;
}

.typing-dot--1 {
  animation-delay: 0s;
}

.typing-dot--2 {
  animation-delay: 0.2s;
}

.typing-dot--3 {
  animation-delay: 0.4s;
}

@keyframes typing-bounce {
  0%, 80%, 100% {
    transform: scale(0.6);
    opacity: 0.4;
  }
  40% {
    transform: scale(1);
    opacity: 1;
  }
}

/* 项目草稿卡片 */
.draft-card {
  background: rgba(255, 255, 255, 0.95);
  border: 1rpx solid var(--color-card-border);
  border-radius: var(--radius-page-card);
  overflow: hidden;
  box-shadow: var(--shadow-medium);
}

.draft-card-header {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx;
  background: linear-gradient(135deg, rgba(139, 108, 246, 0.08), rgba(180, 157, 251, 0.12));
  border-bottom: 1rpx solid var(--color-card-border);
}

.draft-card-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.draft-card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-primary);
}

.draft-card-body {
  padding: 24rpx 28rpx;
}

.draft-field {
  margin-bottom: 16rpx;
}

.draft-field:last-child {
  margin-bottom: 0;
}

.draft-label {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  display: block;
  margin-bottom: 4rpx;
}

.draft-value {
  font-size: 28rpx;
  color: var(--color-text-title);
  font-weight: 500;
}

.draft-card-actions {
  display: flex;
  padding: 20rpx 28rpx;
  border-top: 1rpx solid var(--color-card-border);
}

.draft-btn {
  flex: 1;
  height: 72rpx;
  border-radius: var(--radius-capsule);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 600;
  margin-right: 16rpx;
}

.draft-btn:last-child {
  margin-right: 0;
}

.draft-btn--edit {
  background: var(--color-primary-faint);
  color: var(--color-primary);
}

.draft-btn--confirm {
  background: linear-gradient(135deg, #8B6CF6, #B49DFB);
  color: #FFFFFF;
  box-shadow: 0 4px 16px rgba(139, 108, 246, 0.25);
}

.draft-btn:active {
  opacity: 0.85;
}

/* 底部输入区域 */
.input-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  background: rgba(247, 245, 255, 0.95);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-top: 1rpx solid rgba(237, 232, 254, 0.6);
}

.input-capsule {
  display: flex;
  align-items: center;
  background: var(--color-input-bg);
  border-radius: var(--radius-capsule);
  padding: 8rpx 8rpx 8rpx 28rpx;
}

.chat-input {
  flex: 1;
  height: 72rpx;
  font-size: 28rpx;
  color: var(--color-text-body);
  background: transparent;
}

.input-placeholder {
  color: var(--color-text-placeholder);
  font-size: 28rpx;
}

.send-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: var(--color-divider);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.3s ease;
}

.send-btn--active {
  background: linear-gradient(135deg, #8B6CF6, #B49DFB);
  box-shadow: 0 4px 12px rgba(139, 108, 246, 0.3);
}

.send-icon {
  font-size: 28rpx;
  color: #FFFFFF;
  margin-left: 2rpx;
}

.send-btn:not(.send-btn--active) .send-icon {
  color: var(--color-text-placeholder);
}
