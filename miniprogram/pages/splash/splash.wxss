.splash-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: linear-gradient(160deg, #1A1A2E 0%, #2D1B69 45%, #1A1A2E 100%);
  position: relative;
  overflow: hidden;
  padding: 0 32rpx;
  box-sizing: border-box;
}

.glow-top {
  position: absolute;
  top: 10%;
  left: 50%;
  transform: translateX(-50%);
  width: 560rpx;
  height: 560rpx;
  background: radial-gradient(circle, rgba(139,108,246,0.22) 0%, transparent 70%);
  pointer-events: none;
}

/* Logo */
.logo-section {
  margin-top: 120rpx;
  position: relative;
  width: 192rpx;
  height: 192rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.logo-ring {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  border: 3rpx solid rgba(180, 157, 251, 0.5);
}

.ring-1 { animation: pulse-ring 2.4s ease-out infinite; }
.ring-2 { animation: pulse-ring 2.4s ease-out infinite 0.5s; }
.ring-3 { animation: pulse-ring 2.4s ease-out infinite 1s; }

@keyframes pulse-ring {
  0% { transform: scale(1); opacity: 0.18; }
  100% { transform: scale(1.6); opacity: 0; }
}

.logo-circle {
  width: 128rpx;
  height: 128rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #8B6CF6, #B49DFB);
  display: flex;
  align-items: center;
  justify-content: center;
  animation: breathe 3s ease-in-out infinite;
  z-index: 1;
}

@keyframes breathe {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.03); }
}

.logo-icon {
  font-size: 56rpx;
}

/* Brand */
.brand-section {
  margin-top: 40rpx;
  text-align: center;
}

.brand-name {
  display: block;
  font-size: 56rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 2rpx;
}

.brand-slogan {
  display: block;
  font-size: 26rpx;
  color: rgba(180, 157, 251, 0.75);
  margin-top: 16rpx;
  letter-spacing: 2rpx;
}

/* Divider */
.divider-line {
  width: 320rpx;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, rgba(180,157,251,0.4), transparent);
  margin: 48rpx 0;
}

/* Features */
.features-row {
  display: flex;
  width: 100%;
}

.feature-card {
  flex: 1;
  background: rgba(255,255,255,0.06);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1rpx solid rgba(180,157,251,0.18);
  border-radius: 28rpx;
  padding: 28rpx 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 16rpx;
}

.feature-card:last-child {
  margin-right: 0;
}

.feature-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.feature-label {
  font-size: 24rpx;
  font-weight: 600;
  color: rgba(255,255,255,0.9);
  margin-bottom: 12rpx;
}

.feature-sub {
  font-size: 20rpx;
  color: rgba(180,157,251,0.7);
}

/* Version badge */
.version-badge {
  margin-top: 36rpx;
  display: flex;
  align-items: center;
  background: rgba(139,108,246,0.15);
  border: 1rpx solid rgba(139,108,246,0.3);
  border-radius: 40rpx;
  padding: 10rpx 28rpx;
}

.version-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #34C759;
  margin-right: 12rpx;
}

.version-text {
  font-size: 22rpx;
  color: #B49DFB;
  font-weight: 500;
}

/* CTA */
.cta-section {
  position: absolute;
  bottom: 80rpx;
  left: 32rpx;
  right: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.start-btn {
  width: 100%;
  height: 108rpx;
  border-radius: 40rpx;
  background: linear-gradient(135deg, #8B6CF6 0%, #B49DFB 60%, #C4B5FD 100%);
  color: #fff;
  font-size: 34rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow: 0 8px 32px rgba(139, 108, 246, 0.45), inset 0 1px 0 rgba(255,255,255,0.25);
  letter-spacing: 2rpx;
  margin-bottom: 24rpx;
}

.start-btn::after {
  border: none;
}

.btn-arrow {
  font-size: 36rpx;
  margin-left: 16rpx;
}

.login-link {
  font-size: 26rpx;
  color: rgba(180, 157, 251, 0.55);
  background: none;
}
