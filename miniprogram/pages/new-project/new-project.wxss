/* 新建项目页 */
.page {
  min-height: 100vh;
  background-color: var(--color-bg);
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
  overflow-x: hidden;
}

/* 自定义导航栏 */
.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: rgba(247, 245, 255, 0.90);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border-bottom: 1px solid rgba(237, 232, 254, 0.6);
}

.nav-status {
  width: 100%;
}

.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 32rpx;
}

.nav-back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-back-icon {
  width: 40rpx;
  height: 40rpx;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--color-text-title);
}

.nav-placeholder {
  width: 64rpx;
}

/* 表单区域 */
.form-area {
  padding: 0 32rpx;
  margin-top: calc(var(--status-bar-height, 20px) + 88rpx + 24rpx);
}

.form-group {
  margin-bottom: 40rpx;
}

.form-label {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.label-text {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-title);
}

.label-required {
  font-size: 28rpx;
  color: var(--color-danger);
  margin-left: 4rpx;
}

/* 输入框 */
.form-input {
  width: 100%;
  height: 88rpx;
  background: var(--color-input-bg);
  border-radius: var(--radius-input);
  padding: 0 24rpx;
  font-size: 28rpx;
  color: var(--color-text-body);
  box-sizing: border-box;
}

.input-placeholder {
  color: var(--color-text-placeholder);
  font-size: 28rpx;
}

/* 文本域 */
.form-textarea {
  width: 100%;
  min-height: 200rpx;
  background: var(--color-input-bg);
  border-radius: var(--radius-input);
  padding: 24rpx;
  font-size: 28rpx;
  color: var(--color-text-body);
  box-sizing: border-box;
  line-height: 1.6;
}

.textarea-counter {
  text-align: right;
  font-size: 22rpx;
  color: var(--color-text-placeholder);
  margin-top: 8rpx;
}

/* 研究类型卡片 */
.type-cards {
  display: flex;
}

.type-card {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 28rpx 16rpx;
  background: rgba(255, 255, 255, 0.85);
  border: 2rpx solid var(--color-card-border);
  border-radius: var(--radius-page-card);
  transition: all 0.3s ease;
  margin-right: 16rpx;
}

.type-card:last-child {
  margin-right: 0;
}

.type-card--active {
  background: var(--color-primary-faint);
  border-color: var(--color-primary);
}

.type-card-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.type-card-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text-title);
  margin-bottom: 4rpx;
}

.type-card--active .type-card-title {
  color: var(--color-primary);
}

.type-card-desc {
  font-size: 20rpx;
  color: var(--color-text-secondary);
}

.type-card--active .type-card-desc {
  color: var(--color-primary-light);
}

/* AI 建议横幅 */
.ai-banner {
  margin: 16rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  background: linear-gradient(135deg, rgba(139, 108, 246, 0.08), rgba(180, 157, 251, 0.12));
  border: 1rpx solid rgba(139, 108, 246, 0.15);
  border-radius: var(--radius-page-card);
}

.ai-banner-left {
  display: flex;
  align-items: center;
}

.ai-banner-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #8B6CF6, #B49DFB);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 20rpx;
}

.ai-banner-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-primary);
}

.ai-banner-desc {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  margin-top: 4rpx;
}

.ai-banner-arrow {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.arrow-icon {
  font-size: 40rpx;
  color: var(--color-primary);
  font-weight: 300;
}

/* 底部区域 */
.bottom-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 32rpx calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(247, 245, 255, 0.95);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
}

.create-btn {
  width: 100%;
  height: 96rpx;
  border-radius: var(--radius-capsule);
  background: linear-gradient(135deg, #8B6CF6, #B49DFB);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow: 0 8px 24px rgba(139, 108, 246, 0.25);
}

.create-btn::after {
  border: none;
}

.create-btn--disabled {
  opacity: 0.5;
  box-shadow: none;
}

.create-btn:active:not(.create-btn--disabled) {
  opacity: 0.9;
  transform: scale(0.98);
}
