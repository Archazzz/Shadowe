/* 报告页 - iOS 液态玻璃风格 */
.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #F7F5FF 0%, #EDE8FE 100%);
  display: flex;
  flex-direction: column;
  overflow-x: hidden;
  position: relative;
}

/* 环境光晕 */
.page::before {
  content: '';
  position: absolute;
  top: -200rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 600rpx;
  height: 600rpx;
  background: radial-gradient(circle, rgba(139, 108, 246, 0.1) 0%, transparent 70%);
  pointer-events: none;
  z-index: 0;
}

/* Custom Nav - 液态玻璃 */
.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: rgba(247, 245, 255, 0.85);
  backdrop-filter: blur(32px) saturate(180%);
  -webkit-backdrop-filter: blur(32px) saturate(180%);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.3);
  box-shadow: 0 4px 24rpx rgba(139, 108, 246, 0.06);
}

.nav-status {
  width: 100%;
}

.nav-bar {
  padding: 16rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: sticky;
  top: 0;
  z-index: 10;
}

.nav-left {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.5);
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.nav-left:active {
  background: rgba(139, 108, 246, 0.15);
  transform: scale(0.95);
}

.nav-icon {
  font-size: 36rpx;
  color: #1A1A2E;
}

.nav-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1A1A2E;
  letter-spacing: 1rpx;
}

.nav-right {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.5);
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.nav-right:active {
  background: rgba(139, 108, 246, 0.15);
  transform: scale(0.95);
}

/* Content Scroll */
.content-scroll {
  padding: 16rpx 32rpx;
  padding-top: calc(var(--status-bar-height, 20px) + 88rpx + 16rpx);
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  overflow-x: hidden;
  position: relative;
  z-index: 1;
  flex: 1;
}

/* Report Header Card */
.report-header-card {
  background: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(24px);
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8px 32rpx rgba(139, 108, 246, 0.08), inset 0 1rpx 0 rgba(255,255,255,0.8);
}

.report-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1A1A2E;
  margin-bottom: 12rpx;
  letter-spacing: 1rpx;
}

.report-meta {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #666677;
  margin-right: 24rpx;
}

.meta-item:last-child {
  margin-right: 0;
}

.meta-icon {
  font-size: 24rpx;
  margin-right: 6rpx;
}

/* Summary Section */
.summary-section {
  margin-bottom: 24rpx;
}

.summary-card {
  background: linear-gradient(135deg, rgba(139, 108, 246, 0.08), rgba(180, 157, 251, 0.12));
  backdrop-filter: blur(16px);
  border: 1rpx solid rgba(139, 108, 246, 0.15);
  border-radius: 28rpx;
  padding: 28rpx;
  box-shadow: 0 4px 20rpx rgba(139, 108, 246, 0.08);
}

.summary-label {
  font-size: 22rpx;
  color: #8B6CF6;
  font-weight: 600;
  letter-spacing: 1rpx;
  display: block;
  margin-bottom: 10rpx;
}

.summary-text {
  font-size: 28rpx;
  color: #1A1A2E;
  line-height: 1.6;
  display: block;
}

/* Insights Section */
.insights-section {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1A1A2E;
  margin-bottom: 20rpx;
  letter-spacing: 1rpx;
}

.insight-card {
  background: rgba(255, 255, 255, 0.5);
  backdrop-filter: blur(16px);
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  border-radius: 28rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4px 20rpx rgba(139, 108, 246, 0.06);
  transition: all 0.2s ease;
}

.insight-card:last-child {
  margin-bottom: 0;
}

.insight-card:active {
  transform: scale(0.98);
}

.insight-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.insight-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.insight-type {
  font-size: 24rpx;
  font-weight: 700;
  color: #8B6CF6;
  background: rgba(139, 108, 246, 0.1);
  padding: 6rpx 20rpx;
  border-radius: 40rpx;
  border: 1rpx solid rgba(139, 108, 246, 0.2);
}

.insight-text {
  font-size: 28rpx;
  color: #333344;
  line-height: 1.6;
  display: block;
}

/* Evidence Section */
.evidence-section {
  margin-bottom: 24rpx;
}

.evidence-card {
  background: rgba(255, 255, 255, 0.5);
  backdrop-filter: blur(16px);
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  border-radius: 28rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4px 16rpx rgba(139, 108, 246, 0.06);
}

.evidence-card:last-child {
  margin-bottom: 0;
}

.ev-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.ev-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: rgba(237, 232, 254, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #8B6CF6;
  flex-shrink: 0;
  margin-right: 12rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.6);
}

.ev-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.ev-name {
  font-size: 26rpx;
  font-weight: 700;
  color: #1A1A2E;
  margin-bottom: 4rpx;
}

.ev-time {
  font-size: 22rpx;
  color: #9999AA;
}

.ev-text {
  font-size: 26rpx;
  color: #333344;
  line-height: 1.6;
  display: block;
  margin-bottom: 12rpx;
}

.ev-play-btn {
  display: flex;
  align-items: center;
  background: rgba(139, 108, 246, 0.1);
  border: 1rpx solid rgba(139, 108, 246, 0.2);
  border-radius: 40rpx;
  padding: 10rpx 24rpx;
  align-self: flex-start;
}

.play-icon {
  font-size: 22rpx;
  color: #8B6CF6;
  margin-right: 8rpx;
}

.play-label {
  font-size: 22rpx;
  color: #8B6CF6;
  font-weight: 600;
}

/* Bottom CTA */
.bottom-cta {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(247, 245, 255, 0.85);
  backdrop-filter: blur(32px) saturate(180%);
  -webkit-backdrop-filter: blur(32px) saturate(180%);
  border-top: 1rpx solid rgba(255, 255, 255, 0.4);
  box-shadow: 0 -4px 24rpx rgba(139, 108, 246, 0.06);
  z-index: 100;
}

.cta-button {
  width: 100%;
  height: 96rpx;
  border-radius: 40rpx;
  background: linear-gradient(135deg, #8B6CF6, #B49DFB);
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow: 0 8px 28rpx rgba(139, 108, 246, 0.35), inset 0 1rpx 0 rgba(255,255,255,0.2);
  transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  letter-spacing: 1rpx;
}

.cta-button::after {
  border: none;
}

.cta-button:active {
  opacity: 0.9;
  transform: scale(0.97);
  box-shadow: 0 4px 20rpx rgba(139, 108, 246, 0.25);
}
