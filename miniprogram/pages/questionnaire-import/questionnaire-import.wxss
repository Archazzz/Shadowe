/* 问卷导入页 - iOS 液态玻璃风格 */
.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #F7F5FF 0%, #EDE8FE 100%);
  padding-bottom: 160rpx;
  overflow-x: hidden;
  position: relative;
}

/* 环境光晕 */
.page::before {
  content: '';
  position: absolute;
  top: -200rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 600rpx;
  height: 600rpx;
  background: radial-gradient(circle, rgba(139, 108, 246, 0.1) 0%, transparent 70%);
  pointer-events: none;
  z-index: 0;
}

/* Custom Header - 液态玻璃 */
.custom-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: rgba(247, 245, 255, 0.85);
  backdrop-filter: blur(32px) saturate(180%);
  -webkit-backdrop-filter: blur(32px) saturate(180%);
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.3);
  box-shadow: 0 4px 24rpx rgba(139, 108, 246, 0.06);
}

.header-status {
  width: 100%;
}

/* Header */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
  background: transparent;
  position: sticky;
  top: 0;
  z-index: 100;
}

.header-left, .header-right {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.5);
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  transition: all 0.2s ease;
}

.header-left:active, .header-right:active {
  background: rgba(139, 108, 246, 0.15);
  transform: scale(0.95);
}

.header-icon {
  font-size: 48rpx;
  color: #1A1A2E;
  font-weight: 300;
}

.header-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1A1A2E;
  letter-spacing: 1rpx;
}

.header-close {
  font-size: 36rpx;
  color: #666677;
}

/* Step Indicator - 液态进度条 */
.step-indicator {
  padding: 32rpx 48rpx 24rpx;
  position: relative;
  z-index: 1;
}

.step-track {
  height: 6rpx;
  background: rgba(237, 232, 254, 0.6);
  border-radius: 3rpx;
  position: relative;
  margin-bottom: 24rpx;
  overflow: hidden;
}

.step-progress {
  height: 100%;
  background: linear-gradient(90deg, #8B6CF6, #B49DFB);
  border-radius: 3rpx;
  transition: width 500ms cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 2px 12rpx rgba(139, 108, 246, 0.3);
}

.steps {
  display: flex;
  justify-content: space-between;
}

.step-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.step-dot {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.8);
  backdrop-filter: blur(8px);
  color: #9999AA;
  font-size: 24rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 300ms cubic-bezier(0.4, 0, 0.2, 1);
  margin-bottom: 8rpx;
  border: 2rpx solid rgba(237, 232, 254, 0.8);
  box-shadow: 0 2px 8rpx rgba(139, 108, 246, 0.08);
}

.step-item.active .step-dot {
  background: linear-gradient(135deg, #8B6CF6, #B49DFB);
  color: #fff;
  border-color: transparent;
  box-shadow: 0 4px 20rpx rgba(139, 108, 246, 0.35), inset 0 1rpx 0 rgba(255,255,255,0.3);
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0% { box-shadow: 0 4px 20rpx rgba(139, 108, 246, 0.35), inset 0 1rpx 0 rgba(255,255,255,0.3); }
  50% { box-shadow: 0 4px 28rpx rgba(139, 108, 246, 0.5), inset 0 1rpx 0 rgba(255,255,255,0.3); }
  100% { box-shadow: 0 4px 20rpx rgba(139, 108, 246, 0.35), inset 0 1rpx 0 rgba(255,255,255,0.3); }
}

.step-item.done .step-dot {
  background: linear-gradient(135deg, #34C759, #5DD878);
  color: #fff;
  border-color: transparent;
  box-shadow: 0 4px 16rpx rgba(52, 199, 89, 0.3);
}

.step-label {
  font-size: 24rpx;
  color: #9999AA;
  font-weight: 500;
}

.step-item.active .step-label {
  color: #8B6CF6;
  font-weight: 600;
}

.step-item.done .step-label {
  color: #34C759;
}

/* Step Content */
.step-content {
  padding: 0 32rpx;
  position: relative;
  z-index: 1;
}

/* Import Cards - 液态玻璃卡片 */
.import-cards {
  display: flex;
  margin-top: 24rpx;
}

.import-card {
  flex: 1;
  background: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(16px);
  border: 2rpx dashed rgba(139, 108, 246, 0.25);
  border-radius: 28rpx;
  padding: 48rpx 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: all 200ms cubic-bezier(0.4, 0, 0.2, 1);
  margin-right: 24rpx;
  box-shadow: 0 4px 16rpx rgba(139, 108, 246, 0.06);
}

.import-card:last-child {
  margin-right: 0;
}

.import-card:active {
  border-color: #8B6CF6;
  border-style: solid;
  background: rgba(139, 108, 246, 0.08);
  transform: scale(0.96);
  box-shadow: 0 4px 20rpx rgba(139, 108, 246, 0.15);
}

.import-card-icon {
  font-size: 56rpx;
  margin-bottom: 16rpx;
}

.import-card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1A1A2E;
  margin-bottom: 8rpx;
}

.import-card-desc {
  font-size: 24rpx;
  color: #9999AA;
}

/* Processing */
.processing {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.processing-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 4rpx solid rgba(237, 232, 254, 0.6);
  border-top-color: #8B6CF6;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 24rpx;
  box-shadow: 0 4px 16rpx rgba(139, 108, 246, 0.15);
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.processing-text {
  font-size: 28rpx;
  color: #8B6CF6;
  font-weight: 600;
  letter-spacing: 1rpx;
}

/* Data Preview */
.data-preview {
  margin-top: 24rpx;
}

.preview-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.preview-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1A1A2E;
}

.preview-source {
  font-size: 24rpx;
  color: #8B6CF6;
  background: rgba(139, 108, 246, 0.1);
  padding: 6rpx 20rpx;
  border-radius: 40rpx;
  border: 1rpx solid rgba(139, 108, 246, 0.2);
  font-weight: 600;
}

.preview-stats {
  display: flex;
  margin-bottom: 20rpx;
}

.preview-stat {
  font-size: 26rpx;
  color: #666677;
  margin-right: 32rpx;
  font-weight: 500;
}

.preview-stat:last-child {
  margin-right: 0;
}

/* Quality Badges */
.quality-badges {
  display: flex;
  margin-bottom: 24rpx;
}

.quality-badge {
  display: flex;
  align-items: center;
  padding: 10rpx 20rpx;
  background: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(8px);
  border-radius: 16rpx;
  border: 1rpx solid rgba(237, 232, 254, 0.6);
  margin-right: 24rpx;
  box-shadow: 0 2px 8rpx rgba(139, 108, 246, 0.06);
}

.quality-badge:last-child {
  margin-right: 0;
}

.badge-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-right: 8rpx;
}

.badge-label {
  font-size: 24rpx;
  color: #666677;
  font-weight: 500;
}

.badge-count {
  font-size: 24rpx;
  font-weight: 700;
  color: #1A1A2E;
  margin-left: 6rpx;
}

/* Preview Table - 液态玻璃表格 */
.preview-table {
  background: rgba(255, 255, 255, 0.5);
  backdrop-filter: blur(16px);
  border-radius: 24rpx;
  overflow: hidden;
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  box-shadow: 0 4px 20rpx rgba(139, 108, 246, 0.06);
}

.table-row {
  display: flex;
  padding: 18rpx 20rpx;
  border-bottom: 1rpx solid rgba(240, 237, 248, 0.6);
}

.table-row:last-child {
  border-bottom: none;
}

.table-header {
  background: rgba(247, 245, 255, 0.6);
  font-weight: 700;
  color: #666677;
  font-size: 24rpx;
}

.table-cell {
  flex: 1;
  font-size: 24rpx;
  color: #333344;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.table-cell.wide {
  flex: 2.5;
}

.quality-high {
  color: #34C759;
  font-weight: 600;
}

.quality-medium {
  color: #FF9500;
  font-weight: 600;
}

.quality-low {
  color: #9999AA;
}

/* Summary Card */
.summary-card {
  padding: 32rpx;
  margin-bottom: 32rpx;
  background: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(24px);
  border-radius: 32rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  box-shadow: 0 8px 32rpx rgba(139, 108, 246, 0.08);
}

.summary-row {
  display: flex;
  align-items: center;
  justify-content: space-around;
}

.summary-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.summary-item.highlight .summary-number {
  color: #8B6CF6;
  font-size: 48rpx;
  text-shadow: 0 2px 12rpx rgba(139, 108, 246, 0.2);
}

.summary-number {
  font-size: 40rpx;
  font-weight: 700;
  color: #1A1A2E;
  margin-bottom: 8rpx;
}

.summary-label {
  font-size: 24rpx;
  color: #666677;
  font-weight: 500;
}

.summary-arrow {
  font-size: 36rpx;
  color: #B49DFB;
  font-weight: 300;
}

/* Section Title */
.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1A1A2E;
  margin-bottom: 20rpx;
  letter-spacing: 1rpx;
}

/* Strategy Grid */
.strategy-grid {
  display: flex;
  flex-wrap: wrap;
  margin-bottom: 32rpx;
}

.strategy-card {
  width: 50%;
  box-sizing: border-box;
  padding-right: 20rpx;
  margin-bottom: 20rpx;
  background: rgba(255, 255, 255, 0.5);
  backdrop-filter: blur(16px);
  border: 2rpx solid rgba(237, 232, 254, 0.6);
  border-radius: 28rpx;
  padding: 28rpx 20rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: all 200ms cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 4px 16rpx rgba(139, 108, 246, 0.06);
}

.strategy-card.selected {
  border-color: #8B6CF6;
  background: rgba(139, 108, 246, 0.08);
  box-shadow: 0 4px 24rpx rgba(139, 108, 246, 0.18);
  transform: translateY(-4rpx);
}

.strategy-card:active:not(.selected) {
  transform: scale(0.97);
}

.strategy-icon {
  font-size: 44rpx;
  margin-bottom: 8rpx;
}

.strategy-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #1A1A2E;
  margin-bottom: 8rpx;
}

.strategy-desc {
  font-size: 22rpx;
  color: #9999AA;
  text-align: center;
  line-height: 1.4;
}

/* Candidate List */
.candidate-list {
  display: flex;
  flex-direction: column;
}

.candidate-card {
  padding: 24rpx;
  margin-bottom: 16rpx;
  background: rgba(255, 255, 255, 0.5);
  backdrop-filter: blur(16px);
  border-radius: 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  box-shadow: 0 4px 16rpx rgba(139, 108, 246, 0.06);
  transition: all 0.2s ease;
}

.candidate-card:active {
  transform: scale(0.98);
}

.candidate-card:last-child {
  margin-bottom: 0;
}

.candidate-header {
  display: flex;
  align-items: center;
}

.candidate-rank {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #8B6CF6, #B49DFB);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 16rpx;
  box-shadow: 0 4px 16rpx rgba(139, 108, 246, 0.3), inset 0 1rpx 0 rgba(255,255,255,0.2);
}

.rank-number {
  font-size: 24rpx;
  font-weight: 700;
  color: #fff;
}

.candidate-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.candidate-id {
  font-size: 28rpx;
  font-weight: 700;
  color: #1A1A2E;
  margin-bottom: 4rpx;
}

.candidate-reason {
  font-size: 24rpx;
  color: #666677;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.candidate-score {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
}

.score-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #8B6CF6;
  text-shadow: 0 2px 8rpx rgba(139, 108, 246, 0.2);
}

.score-label {
  font-size: 20rpx;
  color: #9999AA;
}

.expand-icon {
  font-size: 36rpx;
  color: #9999AA;
  transition: transform 200ms ease;
  flex-shrink: 0;
}

.expand-icon.expanded {
  transform: rotate(90deg);
}

/* Dimensions */
.candidate-dimensions {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(237, 232, 254, 0.6);
}

.dimension-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.dimension-row:last-child {
  margin-bottom: 0;
}

.dim-label {
  font-size: 24rpx;
  color: #666677;
  width: 120rpx;
  flex-shrink: 0;
  margin-right: 16rpx;
  font-weight: 500;
}

.dim-bar {
  flex: 1;
  height: 12rpx;
  background: rgba(237, 232, 254, 0.6);
  border-radius: 6rpx;
  overflow: hidden;
}

.dim-fill {
  height: 100%;
  background: linear-gradient(90deg, #8B6CF6, #B49DFB);
  border-radius: 6rpx;
  transition: width 500ms cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 1px 4rpx rgba(139, 108, 246, 0.2);
}

.dim-score {
  font-size: 24rpx;
  font-weight: 700;
  color: #8B6CF6;
  width: 60rpx;
  text-align: right;
  flex-shrink: 0;
}

/* Success Card */
.success-card {
  padding: 32rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(16px);
  border-radius: 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  box-shadow: 0 4px 20rpx rgba(139, 108, 246, 0.08);
}

.success-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.success-info {
  display: flex;
  flex-direction: column;
}

.success-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1A1A2E;
  margin-bottom: 4rpx;
}

.success-desc {
  font-size: 24rpx;
  color: #666677;
}

/* Question Cards */
.question-cards {
  display: flex;
  flex-direction: column;
}

.question-group {
  background: rgba(255, 255, 255, 0.5);
  backdrop-filter: blur(16px);
  border-radius: 28rpx;
  border: 1rpx solid rgba(237, 232, 254, 0.6);
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 4px 16rpx rgba(139, 108, 246, 0.06);
}

.question-group:last-child {
  margin-bottom: 0;
}

.group-header {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  background: rgba(247, 245, 255, 0.6);
  border-bottom: 1rpx solid rgba(237, 232, 254, 0.6);
}

.group-avatar {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.group-id {
  font-size: 28rpx;
  font-weight: 700;
  color: #1A1A2E;
  flex: 1;
}

.group-score {
  font-size: 26rpx;
  font-weight: 700;
  color: #8B6CF6;
  background: rgba(139, 108, 246, 0.1);
  padding: 6rpx 20rpx;
  border-radius: 40rpx;
  border: 1rpx solid rgba(139, 108, 246, 0.2);
}

.question-card {
  padding: 24rpx;
  border-bottom: 1rpx solid rgba(240, 237, 248, 0.6);
}

.question-card:last-child {
  border-bottom: none;
}

.question-type {
  display: inline-flex;
  padding: 6rpx 20rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.question-text {
  font-size: 28rpx;
  color: #333344;
  line-height: 1.6;
  display: block;
  margin-bottom: 12rpx;
}

.question-followup {
  display: flex;
  align-items: center;
  padding: 10rpx 16rpx;
  background: rgba(247, 245, 255, 0.6);
  border-radius: 16rpx;
}

.followup-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.followup-text {
  font-size: 24rpx;
  color: #8B6CF6;
  font-weight: 600;
}

/* Bottom CTA - 液态玻璃按钮 */
.bottom-cta {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: rgba(247, 245, 255, 0.85);
  backdrop-filter: blur(32px) saturate(180%);
  -webkit-backdrop-filter: blur(32px) saturate(180%);
  border-top: 1rpx solid rgba(255, 255, 255, 0.4);
  box-shadow: 0 -4px 24rpx rgba(139, 108, 246, 0.06);
  z-index: 100;
}

.cta-button {
  width: 100%;
  height: 96rpx;
  border-radius: 40rpx;
  background: linear-gradient(135deg, #8B6CF6, #B49DFB);
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow: 0 8px 28rpx rgba(139, 108, 246, 0.35), inset 0 1rpx 0 rgba(255,255,255,0.2);
  transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  letter-spacing: 1rpx;
}

.cta-button::after {
  border: none;
}

.cta-button.disabled {
  background: linear-gradient(135deg, #D4C8FD, #E8E3F7);
  box-shadow: none;
  color: rgba(255, 255, 255, 0.7);
}

.cta-button:active:not(.disabled) {
  opacity: 0.9;
  transform: scale(0.97);
  box-shadow: 0 4px 20rpx rgba(139, 108, 246, 0.25);
}
