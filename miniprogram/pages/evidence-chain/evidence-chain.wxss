/* pages/evidence-chain/evidence-chain.wxss */
.evidence-page {
  min-height: 100vh;
  background: linear-gradient(170deg, #0D0920 0%, #150D3A 50%, #0D0920 100%);
  display: flex;
  flex-direction: column;
  overflow-x: hidden;
  position: relative;
}

/* Ambient glow */
.evidence-page::before {
  content: '';
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 520rpx;
  height: 520rpx;
  background: radial-gradient(circle, rgba(139,108,246,0.16) 0%, transparent 65%);
  pointer-events: none;
  z-index: 0;
}

/* Custom Nav */
.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
}

.nav-status {
  width: 100%;
}

.nav-bar.glass-nav {
  padding: 16rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: relative;
  z-index: 10;
  flex-shrink: 0;
}

.nav-left {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.08);
  border: 1rpx solid rgba(255,255,255,0.12);
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-icon {
  font-size: 36rpx;
  color: rgba(255,255,255,0.8);
}

.nav-title {
  font-size: 32rpx;
  font-weight: 600;
  color: rgba(255,255,255,0.9);
}

.nav-right {
  width: 68rpx;
}

/* Content Scroll */
.content-scroll {
  padding: 16rpx 32rpx;
  box-sizing: border-box;
  overflow-x: hidden;
  position: relative;
  z-index: 1;
}

/* Insight Summary Card */
.insight-summary-card {
  margin: 8rpx 0 0;
  background: linear-gradient(135deg, rgba(124,58,237,0.7), rgba(139,108,246,0.5));
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1rpx solid rgba(139,108,246,0.4);
  border-radius: 36rpx;
  padding: 32rpx;
  box-shadow: 0 8px 32rpx rgba(124,58,237,0.3);
  position: relative;
  z-index: 1;
  flex-shrink: 0;
}

.summary-label {
  font-size: 22rpx;
  color: rgba(255,255,255,0.6);
  font-weight: 500;
  letter-spacing: 2rpx;
  display: block;
  margin-bottom: 10rpx;
}

.summary-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1.35;
  display: block;
  margin-bottom: 10rpx;
}

.summary-desc {
  font-size: 24rpx;
  color: rgba(255,255,255,0.65);
  display: block;
}

/* Evidence hint */
.evidence-hint {
  margin-top: 20rpx;
  margin-bottom: 12rpx;
}

.hint-text {
  font-size: 24rpx;
  color: rgba(255,255,255,0.35);
}

/* Evidence Card */
.evidence-card {
  background: rgba(30,15,72,0.65);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1rpx solid rgba(139,108,246,0.18);
  border-radius: 36rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.ev-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.ev-header .ev-avatar {
  margin-right: 16rpx;
}

.ev-avatar {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  background: rgba(139,108,246,0.2);
  border: 1rpx solid rgba(139,108,246,0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.avatar-text {
  font-size: 28rpx;
}

.ev-user-info {
  flex: 1;
}

.ev-user-name {
  font-size: 26rpx;
  font-weight: 600;
  color: rgba(255,255,255,0.9);
  display: block;
  margin-bottom: 4rpx;
}

.ev-timestamp-row {
  display: flex;
  align-items: center;
}

.timestamp-icon {
  font-size: 20rpx;
  margin-right: 6rpx;
}

.timestamp-text {
  font-size: 22rpx;
  color: #B49DFB;
}

.ev-type-tag {
  font-size: 20rpx;
  font-weight: 600;
  border-radius: 12rpx;
  padding: 4rpx 16rpx;
}

.ev-type-audio {
  color: #B49DFB;
  background: rgba(180,157,251,0.12);
  border: 1rpx solid rgba(180,157,251,0.25);
}

.ev-type-text {
  color: #4D9EFF;
  background: rgba(77,158,255,0.12);
  border: 1rpx solid rgba(77,158,255,0.25);
}

/* Quote */
.ev-quote {
  padding: 20rpx 24rpx;
  background: rgba(255,255,255,0.04);
  border-radius: 20rpx;
  border-left: 4rpx solid rgba(139,108,246,0.45);
  margin-bottom: 20rpx;
}

.quote-text {
  font-size: 26rpx;
  color: rgba(255,255,255,0.7);
  font-style: italic;
  line-height: 1.65;
}

/* Play Button */
.ev-play-btn {
  display: flex;
  align-items: center;
  background: rgba(139,108,246,0.15);
  border: 1rpx solid rgba(139,108,246,0.3);
  border-radius: 40rpx;
  padding: 12rpx 28rpx;
  align-self: flex-start;
}

.play-icon {
  font-size: 24rpx;
  color: #B49DFB;
  margin-right: 12rpx;
}

.play-label {
  font-size: 24rpx;
  color: #B49DFB;
  font-weight: 600;
}

/* Validation Card */
.validation-card {
  background: rgba(30,15,72,0.6);
  border: 1rpx solid rgba(139,108,246,0.18);
  border-radius: 36rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.validation-title {
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(255,255,255,0.85);
  margin-bottom: 20rpx;
  display: block;
}

.validation-item {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.val-icon {
  font-size: 28rpx;
  flex-shrink: 0;
  margin-right: 16rpx;
}

.validation-item:last-child {
  margin-bottom: 0;
}

.val-pass { /* ✅ */ }
.val-warn { /* ⚠️ */ }

.val-label {
  flex: 1;
  font-size: 26rpx;
}

.label-pass {
  color: rgba(255,255,255,0.75);
}

.label-warn {
  color: rgba(255,149,0,0.8);
}

/* Audio Player */
.audio-player {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(30,15,72,0.95);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  border-top: 1rpx solid rgba(139,108,246,0.25);
  padding: 28rpx 32rpx;
  padding-bottom: calc(28rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -8px 32px rgba(0,0,0,0.4);
  z-index: 10;
  transform: translateY(100%);
  transition: transform 300ms cubic-bezier(0.33, 1, 0.68, 1);
}

.player-show {
  transform: translateY(0);
}

.player-controls {
  display: flex;
  align-items: center;
}

.player-play-btn {
  margin-right: 24rpx;
}

.player-play-btn {
  width: 84rpx;
  height: 84rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #7C3AED, #B49DFB);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.player-info {
  flex: 1;
  margin-right: 24rpx;
}

.player-play-icon {
  font-size: 36rpx;
  color: white;
}

.player-status {
  font-size: 24rpx;
  color: rgba(255,255,255,0.45);
  margin-bottom: 10rpx;
  display: block;
}

.player-progress-track {
  background: rgba(255,255,255,0.1);
  border-radius: 6rpx;
  height: 8rpx;
  overflow: hidden;
}

.player-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #7C3AED, #B49DFB);
  border-radius: 6rpx;
  width: 30%;
}

.player-close-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.08);
  border: 1rpx solid rgba(255,255,255,0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.close-icon {
  font-size: 28rpx;
  color: rgba(255,255,255,0.6);
}
