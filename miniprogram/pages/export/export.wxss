/* pages/export/export.wxss */
.export-page {
  min-height: 100vh;
  background: #F7F5FF;
  display: flex;
  flex-direction: column;
  overflow-x: hidden;
}

/* Custom Nav */
.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: rgba(247, 245, 255, 0.92);
  backdrop-filter: blur(24px);
  -webkit-backdrop-filter: blur(24px);
  border-bottom: 1rpx solid rgba(237, 232, 254, 0.7);
}

.nav-status {
  width: 100%;
}

/* Nav */
.nav-bar {
  padding: 16rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: sticky;
  top: 0;
  z-index: 10;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #1A1A2E;
}

.nav-icon {
  font-size: 36rpx;
  color: #333344;
  padding: 8rpx;
}

.nav-left {
  width: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-right {
  width: 60rpx;
}

/* Content */
.content-scroll {
  padding: 24rpx 24rpx 0;
  box-sizing: border-box;
  min-height: calc(100vh - 100rpx);
  overflow-x: hidden;
}

/* Section Label */
.section-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A2E;
  margin-bottom: 16rpx;
  margin-top: 8rpx;
}

/* Format Selection */
.format-row {
  display: flex;
  margin-bottom: 32rpx;
}

.format-card {
  flex: 1;
  background: rgba(255, 255, 255, 0.85);
  border: 2rpx solid #EDE8FE;
  border-radius: 24rpx;
  padding: 24rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: all 0.2s;
  margin-right: 16rpx;
}

.format-card:last-child {
  margin-right: 0;
}

.format-card:active {
  transform: scale(0.96);
}

.format-selected {
  background: #EDE8FE;
  border-color: #8B6CF6;
  box-shadow: 0 4px 16px rgba(139, 108, 246, 0.15);
}

.format-icon-wrap {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 10rpx;
}

.format-icon {
  font-size: 40rpx;
}

.format-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A2E;
  margin-bottom: 10rpx;
}

.format-desc {
  font-size: 20rpx;
  color: #9999AA;
  text-align: center;
}

/* Options Card */
.options-card {
  padding: 8rpx 24rpx;
  margin-bottom: 32rpx;
}

.option-row {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(237, 232, 254, 0.6);
}

.option-row:last-child {
  border-bottom: none;
}

.checkbox {
  width: 40rpx;
  height: 40rpx;
  border-radius: 10rpx;
  border: 2rpx solid #D4C8FD;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s;
  margin-right: 16rpx;
}

.checkbox-checked {
  background: #8B6CF6;
  border-color: #8B6CF6;
}

.checkbox-icon {
  font-size: 24rpx;
  color: #fff;
  font-weight: 700;
}

.option-name {
  font-size: 28rpx;
  color: #333344;
}

/* Progress Section */
.progress-section {
  margin-bottom: 24rpx;
}

.progress-card {
  padding: 28rpx;
}

.progress-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #1A1A2E;
  margin-bottom: 20rpx;
}

.progress-bar-wrap {
  display: flex;
  align-items: center;
}

.progress-bar-track {
  flex: 1;
  height: 16rpx;
  background: #EDE8FE;
  border-radius: 8rpx;
  overflow: hidden;
  margin-right: 16rpx;
}

.progress-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #8B6CF6, #B49DFB);
  border-radius: 8rpx;
  transition: width 400ms ease;
}

.progress-pct {
  font-size: 28rpx;
  color: #8B6CF6;
  font-weight: 700;
  min-width: 80rpx;
  text-align: right;
}

/* Success Section */
.success-section {
  margin-bottom: 24rpx;
}

.success-card {
  background: #fff;
  border: 3rpx solid #34C759;
  border-radius: 24rpx;
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.success-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  background: rgba(52, 199, 89, 0.1);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.success-icon {
  font-size: 40rpx;
  color: #34C759;
  font-weight: 700;
}

.success-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #1A1A2E;
  margin-bottom: 8rpx;
}

.success-desc {
  display: block;
  font-size: 26rpx;
  color: #9999AA;
  margin-bottom: 24rpx;
}

.success-action {
  background: rgba(52, 199, 89, 0.1);
  border-radius: 40rpx;
  padding: 12rpx 40rpx;
}

.success-action-text {
  font-size: 28rpx;
  color: #34C759;
  font-weight: 600;
}

/* Export CTA */
.export-cta {
  margin-top: 16rpx;
}

.cta-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 40rpx;
  background: linear-gradient(135deg, #FF6B9D, #FFB8D1);
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow: 0 8px 24px rgba(255, 107, 157, 0.25);
}

.cta-btn:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.cta-btn::after {
  border: none;
}

.cta-text {
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
}
