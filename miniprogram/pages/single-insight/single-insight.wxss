.insight-page {
  min-height: 100vh;
  background: linear-gradient(170deg, #0D0920 0%, #150D3A 50%, #0D0920 100%);
  display: flex;
  flex-direction: column;
  overflow: hidden;
  position: relative;
}

/* Ambient glow */
.insight-page::before {
  content: '';
  position: absolute;
  top: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 640rpx;
  height: 640rpx;
  background: radial-gradient(circle, rgba(139,108,246,0.18) 0%, transparent 65%);
  pointer-events: none;
  z-index: 0;
}

/* Custom Nav */
.custom-nav {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
}

.nav-status {
  width: 100%;
}

.nav-bar.glass-nav {
  padding: 16rpx 32rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(13,9,32,0.8);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
}

.nav-left, .nav-right {
  width: 68rpx;
  display: flex;
  align-items: center;
}

.nav-icon {
  font-size: 36rpx;
  color: rgba(255,255,255,0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  background: rgba(255,255,255,0.08);
  border: 1rpx solid rgba(255,255,255,0.12);
}

.nav-title {
  font-size: 32rpx;
  font-weight: 600;
  color: rgba(255,255,255,0.9);
  letter-spacing: 2rpx;
}

/* Content Scroll */
.content-scroll {
  position: relative;
  z-index: 1;
}

/* Hero Section */
.hero-section {
  padding: 24rpx 40rpx 0;
  position: relative;
}

.ai-illustration {
  position: absolute;
  right: -16rpx;
  top: -32rpx;
  width: 220rpx;
  height: 220rpx;
  opacity: 0.85;
}

.ai-circle {
  position: absolute;
  border-radius: 50%;
  border-style: solid;
  border-color: rgba(139,108,246,0.18);
  border-width: 1rpx;
}

.ai-outer {
  width: 200rpx;
  height: 100rpx;
  left: 10rpx;
  top: 30rpx;
  border-radius: 50%;
  transform: rotate(-18deg);
}

.ai-middle {
  width: 200rpx;
  height: 100rpx;
  left: 10rpx;
  top: 70rpx;
  border-radius: 50%;
  border-color: rgba(180,157,251,0.12);
  transform: rotate(58deg);
}

.ai-inner {
  width: 136rpx;
  height: 136rpx;
  border-radius: 50%;
  left: 42rpx;
  top: 42rpx;
  background: radial-gradient(circle, rgba(196,181,253,0.45) 0%, rgba(124,58,237,0.3) 55%, rgba(46,16,101,0.05) 100%);
  border: 1.5rpx solid rgba(180,157,251,0.45);
}

.ai-head {
  position: absolute;
  left: 50%;
  top: 38%;
  transform: translateX(-50%);
  width: 52rpx;
  height: 64rpx;
  border: 1.5rpx solid rgba(180,157,251,0.65);
  border-radius: 50% 50% 45% 45%;
}

.ai-eye {
  position: absolute;
  width: 9rpx;
  height: 9rpx;
  border-radius: 50%;
  background: #B49DFB;
  top: 24rpx;
}

.ai-eye-left { left: 14rpx; }
.ai-eye-right { right: 14rpx; }

.orbit-dot {
  position: absolute;
  width: 7rpx;
  height: 7rpx;
  border-radius: 50%;
  background: #B49DFB;
}

.dot-1 { left: 24rpx; top: 36rpx; opacity: 0.5; }
.dot-2 { right: 28rpx; top: 34rpx; opacity: 0.5; }
.dot-3 { left: 12rpx; bottom: 44rpx; opacity: 0.35; }
.dot-4 { right: 8rpx; bottom: 56rpx; opacity: 0.35; }

.hero-text {
  padding-right: 160rpx;
}

.hero-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1.3;
  display: block;
  margin-bottom: 12rpx;
}

.hero-highlight {
  color: #B49DFB;
  text-shadow: 0 0 40rpx rgba(139,108,246,0.6);
}

.hero-subtitle {
  font-size: 26rpx;
  color: rgba(255,255,255,0.45);
  line-height: 1.5;
  display: block;
}

/* Filter Tabs */
.filter-tabs {
  white-space: nowrap;
  padding: 0 40rpx 24rpx;
  margin-top: 24rpx;
}

.filter-tab {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 26rpx;
  border-radius: 40rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.filter-tab:not(.filter-active) {
  background: rgba(255,255,255,0.06);
  border: 1rpx solid rgba(255,255,255,0.1);
}

.filter-active {
  background: linear-gradient(135deg, #7C3AED, #8B6CF6);
  border: 1rpx solid rgba(139,108,246,0.5);
  box-shadow: 0 4px 16rpx rgba(139,108,246,0.3);
}

.filter-text {
  font-size: 26rpx;
  font-weight: 400;
  color: rgba(255,255,255,0.55);
}

.filter-tab.filter-active .filter-text {
  font-weight: 600;
  color: #FFFFFF;
}

.filter-count {
  font-size: 22rpx;
  font-weight: 600;
  color: rgba(255,255,255,0.3);
  margin-left: 8rpx;
}

.filter-tab.filter-active .filter-count {
  color: rgba(255,255,255,0.8);
}

/* Insight List */
.insight-list {
  padding: 0 32rpx;
}

.insight-card {
  background: rgba(30,15,72,0.65);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1rpx solid rgba(139,108,246,0.2);
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4px 24rpx rgba(0,0,0,0.25), inset 0 1rpx 0 rgba(255,255,255,0.05);
}

/* Card Top */
.card-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.tag-row {
  display: flex;
}

.tag-row .tag {
  margin-right: 12rpx;
}

.tag-row .tag:last-child {
  margin-right: 0;
}

.tag {
  font-size: 22rpx;
  font-weight: 600;
  border-radius: 12rpx;
  padding: 4rpx 16rpx;
}

.tag-pain { color: #FF6B6B; background: rgba(255,107,107,0.12); border: 1rpx solid rgba(255,107,107,0.35); }
.tag-need { color: #4D9EFF; background: rgba(77,158,255,0.12); border: 1rpx solid rgba(77,158,255,0.35); }
.tag-behavior { color: #FF9500; background: rgba(255,149,0,0.12); border: 1rpx solid rgba(255,149,0,0.35); }
.tag-suggest { color: #B49DFB; background: rgba(180,157,251,0.12); border: 1rpx solid rgba(180,157,251,0.35); }

.tag-freq-high { color: #FFB300; background: rgba(255,179,0,0.08); border: 1rpx solid rgba(255,179,0,0.3); }
.tag-freq-mid { color: #9999AA; background: rgba(153,153,170,0.08); border: 1rpx solid rgba(153,153,170,0.3); }
.tag-freq-low { color: #666677; background: rgba(102,102,119,0.06); border: 1rpx solid rgba(102,102,119,0.25); }

.interview-count {
  display: flex;
  align-items: center;
}

.interview-icon {
  font-size: 22rpx;
  margin-right: 6rpx;
}

.interview-text {
  font-size: 22rpx;
  color: rgba(180,157,251,0.55);
}

/* Card Body */
.card-body {
  display: flex;
  margin-bottom: 20rpx;
}

.card-text-content {
  flex: 1;
  min-width: 0;
  margin-right: 24rpx;
}

.card-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1.35;
  display: block;
  margin-bottom: 12rpx;
}

.card-desc {
  font-size: 26rpx;
  color: rgba(255,255,255,0.5);
  line-height: 1.55;
  display: block;
  margin-bottom: 20rpx;
}

.card-quote {
  border-left: 3rpx solid rgba(139,108,246,0.4);
  padding-left: 20rpx;
  margin-bottom: 12rpx;
}

.quote-mark {
  font-size: 26rpx;
  color: rgba(180,157,251,0.7);
}

.quote-text {
  font-size: 26rpx;
  color: rgba(180,157,251,0.7);
  font-style: italic;
  line-height: 1.5;
}

/* Impact Ring */
.impact-ring-wrap {
  flex-shrink: 0;
  padding-top: 8rpx;
}

.impact-ring-canvas-wrap {
  width: 144rpx;
  height: 144rpx;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.impact-canvas {
  position: absolute;
  top: 0;
  left: 0;
  width: 144rpx;
  height: 144rpx;
}

.impact-ring-inner {
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  background: rgba(30,15,72,0.95);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  z-index: 1;
}

.impact-value {
  font-size: 34rpx;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1.1;
}

.impact-label {
  font-size: 18rpx;
  color: rgba(255,255,255,0.45);
  margin-top: 2rpx;
}

/* Card Bottom */
.card-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.avatar-cluster {
  display: flex;
  align-items: center;
}

.avatar-item {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(30,15,70,0.8);
  flex-shrink: 0;
}

.avatar-extra {
  font-size: 22rpx;
  color: rgba(255,255,255,0.4);
  margin-left: 8rpx;
}

.evidence-link {
  display: flex;
  align-items: center;
  background: rgba(139,108,246,0.12);
  border: 1rpx solid rgba(139,108,246,0.25);
  border-radius: 40rpx;
  padding: 8rpx 20rpx;
}

.evidence-link-icon {
  font-size: 22rpx;
  margin-right: 8rpx;
}

.evidence-link-text {
  font-size: 22rpx;
  color: #B49DFB;
  font-weight: 500;
}

/* Bottom Hint */
.bottom-hint {
  margin: 8rpx 32rpx 16rpx;
  background: rgba(255,255,255,0.04);
  border: 1rpx solid rgba(255,255,255,0.08);
  border-radius: 24rpx;
  padding: 22rpx 32rpx;
  display: flex;
  align-items: center;
}

.hint-icon-wrap {
  width: 56rpx;
  height: 56rpx;
  border-radius: 16rpx;
  background: rgba(139,108,246,0.15);
  border: 1rpx solid rgba(139,108,246,0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 16rpx;
}

.hint-icon {
  font-size: 28rpx;
}

.hint-text {
  flex: 1;
  font-size: 24rpx;
  color: rgba(255,255,255,0.45);
}

.hint-arrow {
  font-size: 28rpx;
  color: rgba(255,255,255,0.3);
}

/* CTA Section */
.cta-section {
  padding: 0 32rpx 24rpx;
}

.cta-btn {
  width: 100%;
  height: 104rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #7C3AED 0%, #8B6CF6 50%, #B49DFB 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8px 32rpx rgba(124,58,237,0.5), inset 0 1rpx 0 rgba(255,255,255,0.2);
}

.cta-icon {
  font-size: 32rpx;
  color: white;
  margin-right: 16rpx;
}

.cta-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}
