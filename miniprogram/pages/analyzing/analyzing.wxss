.page {
  min-height: 100vh;
  background: linear-gradient(160deg, #1A1A2E 0%, #2D1B69 50%, #1A1A2E 100%);
  display: flex;
  flex-direction: column;
  padding-bottom: env(safe-area-inset-bottom);
}

/* Custom Header */
.custom-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
}

.header-status {
  width: 100%;
}

/* Header */
.header {
  padding: 0 32rpx;
  padding-top: calc(env(safe-area-inset-top) + 24rpx);
}

.header-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 88rpx;
}

.header-left {
  width: 80rpx;
  display: flex;
  align-items: center;
}

.back-arrow {
  width: 40rpx;
  height: 40rpx;
}

.header-right {
  width: 80rpx;
}

.header-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 16rpx;
}

.brand-logo {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 16rpx;
}

.brand-logo.rotating {
  animation: rotate-slow 4s linear infinite;
}

@keyframes rotate-slow {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.material-name {
  font-size: 28rpx;
  color: rgba(180, 157, 251, 0.7);
  margin-bottom: 8rpx;
}

.analyzing-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #FFFFFF;
  letter-spacing: 2rpx;
}

/* Progress Section */
.progress-section {
  display: flex;
  align-items: center;
  padding: 32rpx 32rpx 16rpx;
}

.progress-bar {
  margin-right: 20rpx;
}

.progress-bar {
  flex: 1;
  height: 12rpx;
  background: rgba(45, 45, 69, 0.8);
  border-radius: 6rpx;
  overflow: hidden;
  margin-right: 20rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #8B6CF6, #C4B5FD);
  border-radius: 6rpx;
  position: relative;
  transition: width 0.5s ease;
}

.progress-shimmer {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
  animation: shimmer 1.5s ease-in-out infinite;
}

@keyframes shimmer {
  0% { transform: translateX(-100%); }
  100% { transform: translateX(100%); }
}

.progress-text {
  font-size: 24rpx;
  color: rgba(180, 157, 251, 0.9);
  font-variant-numeric: tabular-nums;
  min-width: 80rpx;
  text-align: right;
}

/* Steps Section */
.steps-section {
  padding: 0 32rpx;
  display: flex;
  flex-direction: column;
  flex: 1;
}

.step-card {
  margin-bottom: 12rpx;
}

.step-card:last-child {
  margin-bottom: 0;
}

.step-card {
  background: rgba(255,255,255,0.03);
  backdrop-filter: blur(20px);
  border: 1.5rpx solid rgba(255,255,255,0.07);
  border-radius: 32rpx;
  padding: 28rpx;
  transition: all 400ms ease;
  margin-bottom: 12rpx;
}

.step-card:last-child {
  margin-bottom: 0;
}

.step-card.step-active {
  background: rgba(139,108,246,0.12);
  border-color: rgba(139,108,246,0.45);
  box-shadow: 0 0 24rpx rgba(139,108,246,0.15);
}

.step-card.step-completed {
  background: rgba(52,199,89,0.08);
  border-color: rgba(52,199,89,0.35);
}

.step-card.step-pending {
  opacity: 0.6;
}

.step-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.agent-badge {
  padding: 6rpx 20rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
}

.badge-kate {
  background: rgba(139,108,246,0.2);
  border: 1rpx solid rgba(139,108,246,0.4);
}

.badge-steven {
  background: rgba(59,130,246,0.2);
  border: 1rpx solid rgba(59,130,246,0.4);
}

.agent-name {
  font-size: 22rpx;
  font-weight: 600;
  color: rgba(255,255,255,0.9);
}

.step-status-icon {
  display: flex;
  align-items: center;
  justify-content: center;
}

.checkmark {
  font-size: 32rpx;
  color: #34C759;
  font-weight: bold;
}

.active-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #8B6CF6;
  animation: pulse-active 1.2s ease-in-out infinite;
}

.step-status-icon.pulsing {
  animation: pulse-ring 1.2s ease-in-out infinite;
}

@keyframes pulse-active {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.5; transform: scale(1.4); }
}

@keyframes pulse-ring {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.2); }
}

.step-body {
  display: flex;
  flex-direction: column;
}

.step-title {
  margin-bottom: 8rpx;
}

.step-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.step-desc {
  font-size: 24rpx;
  color: rgba(180, 157, 251, 0.7);
}

/* Fun Card */
.fun-card {
  margin: 24rpx 32rpx;
  padding: 24rpx 32rpx;
  background: rgba(45, 45, 69, 0.4);
  backdrop-filter: blur(20px);
  border-radius: 24rpx;
  border: 1rpx solid rgba(180, 157, 251, 0.15);
  text-align: center;
  animation: fade-in 0.5s ease;
}

@keyframes fade-in {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.fun-text {
  font-size: 26rpx;
  color: rgba(180, 157, 251, 0.8);
  line-height: 1.6;
}

/* Complete Section */
.complete-section {
  padding: 32rpx;
  display: flex;
  justify-content: center;
  animation: fade-in 0.6s ease;
}

.complete-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #8B6CF6, #7C5CFC);
  border-radius: 24rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 8rpx 32rpx rgba(139, 108, 246, 0.4);
}

.complete-btn-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #FFFFFF;
  letter-spacing: 2rpx;
}
